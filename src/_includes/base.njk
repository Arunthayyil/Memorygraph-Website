<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ pageTitle or title }}</title>
{% if description %}<meta name="description" content="{{ description }}"/>{% endif %}
<meta name="author" content="{{ author or 'Memorygraph Wedding Studio' }}"/>
<meta name="robots" content="{{ robots or 'index, follow' }}"/>
{% if ogTitle or pageTitle or title %}<meta property="og:title" content="{{ ogTitle or pageTitle or title }}"/>{% endif %}
{% if ogDesc or description %}<meta property="og:description" content="{{ ogDesc or description }}"/>{% endif %}
<meta property="og:type" content="{{ ogType or 'website' }}"/>
{% if canonical %}<meta property="og:url" content="{{ canonical }}"/>{% endif %}
{% if ogImage %}<meta property="og:image" content="{{ ogImage }}"/>{% endif %}
<meta property="og:locale" content="en_IN"/>
<meta property="og:site_name" content="Memorygraph Weddings"/>
{% if ogTitle or pageTitle or title %}<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="{{ ogTitle or pageTitle or title }}"/>
{% if ogDesc or description %}<meta name="twitter:description" content="{{ ogDesc or description }}"/>{% endif %}
{% if ogImage %}<meta name="twitter:image" content="{{ ogImage }}"/>{% endif %}{% endif %}
{% if canonical %}<link rel="canonical" href="{{ canonical }}"/>{% endif %}
<link rel="icon" href="/assets/logo/logo-dark.png" type="image/png"/>
<link rel="apple-touch-icon" href="/assets/logo/logo-dark.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/assets/css/global.css"/>
<link rel="stylesheet" href="/assets/css/animations.css"/>
{{ extraHead | safe if extraHead }}
</head>
<body>

<!-- PRELOADER -->
<div class="preloader" id="preloader">
  <div class="preloader-logo">Memorygraph<small>Photographing Memories</small></div>
  <div class="preloader-line"></div>
</div>

<!-- PAGE TRANSITION OVERLAY -->
<div class="page-transition-overlay"></div>

<!-- SKIP LINK -->
<a href="#main" class="skip-link">Skip to content</a>

<!-- NAV -->
<nav id="nav">
  <a href="/" class="nav-logo">
    <img src="/assets/logo/logo-dark.png" alt="Memorygraph Wedding Studio" style="height:48px;width:auto;max-width:160px;display:block;"/>
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/stories/">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/investment/">Investment</a></li>
    <li><a href="/blog/">Journal</a></li>
  </ul>
  <a href="/contact/" class="nav-cta">Begin Your Story</a>
  <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false"><span></span><span></span><span></span></button>
</nav>

<!-- MOBILE MENU -->
<div class="mobile-menu" id="mobileMenu">
  <ul>
    <li><a href="/">Home</a></li>
    <li><a href="/stories/">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/investment/">Investment</a></li>
    <li><a href="/blog/">Journal</a></li>
    <li><a href="/contact/">Contact</a></li>
  </ul>
  <a href="/contact/" class="mobile-menu-cta">Begin Your Story</a>
  <div class="mobile-menu-social">
    <a href="https://instagram.com/memorygraph.weddings" target="_blank" rel="noopener" aria-label="Instagram">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="5"/><circle cx="17.5" cy="6.5" r="1.5" fill="currentColor" stroke="none"/></svg>
    </a>
    <a href="https://wa.me/919846238073" target="_blank" rel="noopener" aria-label="WhatsApp">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.37 0 0 5.37 0 12c0 2.12.56 4.16 1.6 5.97L.1 23.9l6.13-1.47A11.94 11.94 0 0012 24c6.63 0 12-5.37 12-12S18.63 0 12 0zm5.9 16.9c-.24.68-1.42 1.3-1.96 1.38-.5.08-1.14.12-1.84-.12-.42-.14-.96-.34-1.66-.66-2.92-1.34-4.82-4.28-4.97-4.48-.14-.2-1.18-1.56-1.18-2.98s.74-2.12.98-2.38c.26-.28.56-.34.74-.34h.54c.18 0 .42-.06.64.5.24.56.82 2 .88 2.14.08.14.12.32.02.5-.08.2-.14.3-.28.46-.14.16-.3.36-.42.48-.14.14-.3.3-.12.58.16.28.74 1.22 1.6 1.98 1.08.96 2 1.26 2.28 1.4.28.14.44.12.6-.06.16-.2.7-.82.88-1.1.2-.28.38-.24.64-.14.26.1 1.62.76 1.9.9.28.14.46.2.54.32.06.1.06.6-.18 1.28z"/></svg>
    </a>
  </div>
</div>

<!-- MAIN CONTENT -->
<main id="main">
{{ content | safe }}
</main>

<!-- FOOTER -->
<footer>
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <img src="/assets/logo/logo-white.png" alt="Memorygraph Wedding Studio" style="height:52px;width:auto;mix-blend-mode:screen;opacity:.9;"/>
    </a>
    <div class="footer-links-row">
      <a href="/">Home</a>
      <a href="/stories/">Stories</a>
      <a href="/about/">About</a>
      <a href="/investment/">Investment</a>
      <a href="/blog/">Journal</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">&copy; {% year %} Memorygraph Wedding Studio &middot; Thrissur, Kerala</div>
    <div class="footer-copy">+91 98462 38073 &middot; memorygraphweddings@gmail.com</div>
  </div>
</footer>

<!-- MOBILE STICKY CTA -->
<div class="mobile-cta-bar" id="mobileCta">
  <div class="mobile-cta-bar-inner">
    <span class="mobile-cta-bar-text">Season dates filling up</span>
    <a href="/contact/">Begin Your Story</a>
  </div>
</div>

<!-- WHATSAPP -->
<a href="https://wa.me/919846238073?text=Hi%20Arun%2C%20I%27d%20love%20to%20discuss%20my%20wedding." class="whatsapp-float" target="_blank" aria-label="Chat on WhatsApp" rel="noopener">
  <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16 .4C7.4.4.4 7.4.4 16c0 2.84.74 5.62 2.16 8.06L.27 31.6l7.74-2.27C10.36 30.7 13.14 31.5 16 31.5c8.6 0 15.6-7 15.6-15.5C31.6 7.4 24.6.4 16 .4zM16 28.7c-2.5 0-4.96-.66-7.1-1.92l-.5-.3-5.34 1.55 1.6-5.18-.34-.55C2.92 19.92 2.2 18 2.2 16 2.2 8.4 8.4 2.2 16 2.2c7.6 0 13.8 6.2 13.8 13.8 0 7.6-6.2 12.7-13.8 12.7zm7.6-9.8c-.4-.2-2.4-1.18-2.78-1.32-.38-.14-.66-.2-.94.2-.28.4-1.06 1.32-1.3 1.6-.24.28-.48.3-.88.1-.4-.2-1.7-.62-3.24-2-1.2-1.06-2-2.38-2.24-2.78-.24-.4-.02-.62.18-.82.18-.18.4-.46.6-.7.2-.24.26-.4.4-.68.14-.28.06-.52-.04-.72-.1-.2-.92-2.22-1.26-3.04-.34-.8-.68-.7-.94-.72h-.8c-.28 0-.72.1-1.1.5-.38.4-1.44 1.4-1.44 3.42s1.48 3.96 1.68 4.24c.2.28 2.92 4.46 7.08 6.24 1 .42 1.78.68 2.38.88.98.32 1.88.28 2.6.16.78-.12 2.4-.98 2.74-1.92.34-.94.34-1.74.24-1.92-.1-.18-.36-.28-.76-.48z"/></svg>
</a>

<!-- VENDOR SCRIPTS -->
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lenis@1.1/dist/lenis.min.js"></script>

<!-- SHARED INTERACTIONS -->
<script src="/assets/js/main.js"></script>

<!-- CMS LOADER -->
<script src="/assets/cms-loader.js"></script>
{{ extraScripts | safe if extraScripts }}
</body>
</html>
