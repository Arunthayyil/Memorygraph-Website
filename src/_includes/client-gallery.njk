<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="robots" content="noindex, nofollow"/>
<title>{{ title }} | Client Gallery | Memorygraph Wedding Studio</title>
<link rel="icon" href="/assets/logo/logo-dark.png" type="image/png"/>
<link rel="apple-touch-icon" href="/assets/logo/logo-dark.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/assets/css/global.css"/>
<link rel="stylesheet" href="/assets/css/animations.css"/>
<style>
  :root{--paper:#fbf7ef;}
  button,input,textarea,select{font:inherit;}button{cursor:pointer;}

  .screen-lock{position:fixed;inset:0;z-index:500;background:linear-gradient(140deg,rgba(15,56,56,.96),rgba(26,24,20,.96)),url('{{ lock_image or hero_image or "/assets/stories/abhin-gayathry/03.jpg" }}') center/cover;display:grid;place-items:center;padding:24px;color:var(--ivory);}
  .screen-lock.hidden{display:none;}
  .lock-panel{width:min(560px,100%);padding:56px 48px;background:rgba(244,237,224,.08);border:1px solid rgba(244,237,224,.18);backdrop-filter:blur(20px);}
  .lock-logo{height:54px;width:auto;margin-bottom:40px;filter:brightness(0) invert(1);opacity:.92;}
  .lock-label,.eyebrow{font-size:.65rem;letter-spacing:.32em;text-transform:uppercase;color:var(--gold-2);font-weight:400;}
  .lock-title{font-family:var(--serif);font-size:clamp(2.8rem,8vw,5rem);font-weight:300;line-height:.95;margin:22px 0;}
  .lock-title em{font-style:italic;color:var(--gold-2);}
  .lock-copy{max-width:420px;color:rgba(244,237,224,.72);font-size:.92rem;line-height:1.8;margin-bottom:32px;}
  .lock-form{display:grid;grid-template-columns:1fr auto;gap:10px;}
  .lock-form input{min-width:0;padding:15px 16px;background:rgba(244,237,224,.12);border:1px solid rgba(244,237,224,.24);color:var(--ivory);}
  .lock-form input::placeholder{color:rgba(244,237,224,.45);}
  .lock-form input:focus{outline:1px solid var(--gold-2);border-color:var(--gold-2);}
  .lock-error{display:none;margin-top:14px;color:#ffd1c4;font-size:.82rem;}
  .lock-error.visible{display:block;}
  .lock-hint{margin-top:22px;color:rgba(244,237,224,.5);font-size:.72rem;line-height:1.7;}

  .btn{border:0;background:var(--teal);color:var(--ivory);padding:14px 24px;font-size:.68rem;letter-spacing:.22em;text-transform:uppercase;transition:background .25s,color .25s,border-color .25s;text-decoration:none;text-align:center;}
  .btn:hover{background:var(--teal-deep);}
  .btn.gold{background:var(--gold);color:var(--teal-deep);}
  .btn.gold:hover{background:var(--gold-2);}
  .btn.ghost{background:transparent;border:1px solid var(--line);color:var(--ink);}
  .btn.ghost:hover{border-color:var(--teal);color:var(--teal);}

  .gallery-app{position:relative;z-index:2;min-height:100vh;}
  .topbar{position:sticky;top:0;z-index:100;display:flex;align-items:center;justify-content:space-between;gap:24px;padding:16px 40px;background:rgba(244,237,224,.9);backdrop-filter:blur(18px);border-bottom:1px solid var(--line-2);}
  .topbar img{height:44px;width:auto;display:block;}
  .gallery-nav{display:flex;align-items:center;gap:28px;list-style:none;}
  .gallery-nav a{font-family:var(--sans);font-size:.66rem;font-weight:400;letter-spacing:.2em;text-transform:uppercase;color:var(--ink-soft);text-decoration:none;transition:color .25s;}
  .gallery-nav a:hover{color:var(--teal);}
  .top-actions{display:flex;align-items:center;gap:10px;flex-wrap:wrap;justify-content:flex-end;}
  .selection-pill{padding:10px 16px;border:1px solid rgba(29,89,89,.2);color:var(--teal);font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;background:rgba(29,89,89,.04);}

  .hero{min-height:72vh;display:grid;grid-template-columns:1fr .9fr;gap:72px;align-items:end;padding:110px 56px 64px;position:relative;overflow:hidden;}
  .hero-copy{position:relative;z-index:2;max-width:720px;}
  .hero h1{font-family:var(--serif);font-size:clamp(4rem,8vw,8.6rem);font-weight:300;line-height:.96;margin:24px 0;color:var(--ink);}
  .hero h1 em{font-style:italic;color:var(--teal);}
  .hero-sub{max-width:590px;font-size:.96rem;line-height:1.9;color:var(--ink-soft);}
  .hero-meta{display:flex;gap:1px;background:var(--line);margin-top:44px;max-width:760px;}
  .meta-item{background:var(--ivory);padding:22px 24px;min-width:150px;flex:1;}
  .meta-value{display:block;font-family:var(--serif);font-size:2rem;color:var(--teal);line-height:1;}
  .meta-label{display:block;margin-top:8px;font-size:.58rem;letter-spacing:.24em;text-transform:uppercase;color:var(--mist);}
  .hero-frame{position:relative;z-index:1;min-height:520px;align-self:stretch;}
  .hero-photo{position:absolute;inset:0;background:url('{{ hero_image or "/assets/stories/abhin-gayathry/01.jpg" }}') center/cover;box-shadow:0 30px 70px rgba(26,24,20,.13);}
  .hero-photo.small{inset:auto auto 36px -72px;width:44%;height:36%;background:url('{{ hero_image_secondary or hero_image or "/assets/stories/abhin-gayathry/08.jpg" }}') center/cover;border:10px solid var(--ivory);}

  .toolbar{position:sticky;top:77px;z-index:90;display:flex;align-items:center;justify-content:space-between;gap:20px;padding:18px 56px;background:var(--ivory-2);border-top:1px solid var(--line-2);border-bottom:1px solid var(--line-2);}
  .filters{display:flex;gap:8px;flex-wrap:wrap;}
  .filter-btn{padding:10px 16px;border:1px solid var(--line);background:var(--ivory);color:var(--ink-soft);font-size:.65rem;letter-spacing:.18em;text-transform:uppercase;}
  .filter-btn.active{background:var(--teal);border-color:var(--teal);color:var(--ivory);}
  .toolbar-tools{display:flex;gap:10px;align-items:center;}
  .search,.sort-select{min-width:220px;padding:11px 14px;border:1px solid var(--line);background:var(--ivory);color:var(--ink);}
  .sort-select{min-width:170px;}
  .search:focus,.sort-select:focus{outline:1px solid var(--teal);}

  .gallery-wrap{padding:72px 56px 120px;}
  .section-head{display:flex;align-items:end;justify-content:space-between;gap:40px;margin-bottom:40px;}
  .section-title{font-family:var(--serif);font-size:clamp(2.6rem,5vw,4.8rem);font-weight:300;line-height:1.08;color:var(--ink);}
  .section-title em{font-style:italic;color:var(--teal);}
  .section-note{max-width:460px;color:var(--ink-soft);font-size:.86rem;line-height:1.8;}
  .photo-grid{columns:4 230px;column-gap:18px;}
  .photo-card,.quote-card{break-inside:avoid;margin:0 0 18px;position:relative;background:var(--ivory-2);overflow:hidden;border:1px solid var(--line-2);}
  .photo-card.hidden,.quote-card.hidden{display:none;}
  .photo-card img{width:100%;height:auto;display:block;transition:transform .4s,filter .4s;}
  .photo-card:hover img{transform:scale(1.025);filter:saturate(1.04);}
  .quote-card{padding:42px 34px;background:var(--ink);color:var(--ivory);}
  .quote-card blockquote{font-family:var(--serif);font-size:clamp(1.45rem,2.4vw,2.25rem);font-style:italic;font-weight:300;line-height:1.32;color:var(--ivory);}
  .quote-card cite{display:block;margin-top:22px;font-style:normal;font-size:.62rem;letter-spacing:.24em;text-transform:uppercase;color:var(--gold-2);}
  .photo-overlay{position:absolute;inset:0;display:flex;flex-direction:column;justify-content:space-between;padding:14px;background:linear-gradient(180deg,rgba(26,24,20,.44),rgba(26,24,20,0) 42%,rgba(26,24,20,.55));opacity:0;transition:opacity .25s;}
  .photo-card:hover .photo-overlay,.photo-card.selected .photo-overlay{opacity:1;}
  .photo-id{align-self:flex-start;color:var(--ivory);font-size:.58rem;letter-spacing:.24em;text-transform:uppercase;text-shadow:0 2px 12px rgba(0,0,0,.35);}
  .photo-controls{display:flex;gap:8px;align-self:flex-end;}
  .icon-btn{width:42px;height:42px;border:1px solid rgba(244,237,224,.5);background:rgba(26,24,20,.28);color:var(--ivory);display:grid;place-items:center;transition:background .25s,border-color .25s,color .25s;text-decoration:none;}
  .icon-btn:hover{background:var(--ivory);color:var(--teal);border-color:var(--ivory);}
  .photo-card.selected .select-btn{background:var(--gold);border-color:var(--gold);color:var(--teal-deep);}
  .photo-card.selected::after{content:'Selected';position:absolute;top:14px;right:14px;padding:8px 11px;background:var(--gold);color:var(--teal-deep);font-size:.55rem;letter-spacing:.18em;text-transform:uppercase;}

  .album-drawer{position:fixed;right:0;top:0;bottom:0;z-index:220;width:min(460px,100%);background:var(--paper);box-shadow:-24px 0 60px rgba(26,24,20,.18);transform:translateX(100%);transition:transform .35s cubic-bezier(.22,1,.36,1);display:flex;flex-direction:column;}
  .album-drawer.open{transform:translateX(0);}
  .drawer-head{padding:28px 28px 22px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;gap:20px;}
  .drawer-title{font-family:var(--serif);font-size:2rem;font-weight:300;line-height:1;}
  .drawer-close{width:38px;height:38px;border:1px solid var(--line);background:transparent;color:var(--ink);}
  .drawer-body{padding:24px 28px;overflow:auto;flex:1;}
  .selected-list{display:grid;gap:12px;}
  .selected-item{display:grid;grid-template-columns:76px 1fr auto;gap:12px;align-items:center;padding:10px;background:var(--ivory);border:1px solid var(--line-2);}
  .selected-item img{width:76px;height:58px;object-fit:cover;}
  .selected-item strong{font-family:var(--serif);font-size:1.1rem;font-weight:400;display:block;}
  .selected-item span{font-size:.68rem;letter-spacing:.14em;text-transform:uppercase;color:var(--mist);}
  .mini-remove{width:32px;height:32px;border:1px solid var(--line);background:transparent;color:var(--ink);}
  .drawer-foot{padding:22px 28px;border-top:1px solid var(--line);display:grid;gap:12px;}
  .textarea-label{font-size:.6rem;letter-spacing:.22em;text-transform:uppercase;color:var(--mist);}
  .notes,.selector-name{width:100%;padding:13px 14px;border:1px solid var(--line);background:var(--ivory);color:var(--ink);line-height:1.6;}
  .notes{min-height:94px;resize:vertical;}
  .selector-name:focus,.notes:focus{outline:1px solid var(--teal);}
  .export-output{display:none;padding:14px;background:var(--ivory);border:1px solid var(--line);font-size:.78rem;line-height:1.7;color:var(--ink-soft);white-space:pre-wrap;}
  .export-output.visible{display:block;}

  .lightbox{position:fixed;inset:0;z-index:300;background:rgba(15,14,12,.97);display:none;flex-direction:column;color:var(--ivory);}
  .lightbox.open{display:flex;}
  .lb-stage{flex:1;display:flex;align-items:center;justify-content:center;position:relative;min-height:0;overflow:hidden;}
  .lb-stage img{max-width:92vw;max-height:100%;object-fit:contain;box-shadow:0 20px 60px rgba(0,0,0,.4);}
  .lightbox .lb-close,.lightbox .lb-prev,.lightbox .lb-next{position:absolute;border:1px solid rgba(244,237,224,.22);background:rgba(244,237,224,.06);color:var(--ivory);z-index:2;transition:background .2s;}
  .lightbox .lb-close:hover,.lightbox .lb-prev:hover,.lightbox .lb-next:hover{background:rgba(244,237,224,.14);}
  .lb-close{top:16px;right:16px;width:42px;height:42px;font-size:1.2rem;}
  .lb-prev,.lb-next{top:50%;width:44px;height:56px;transform:translateY(-50%);font-size:1.6rem;}
  .lb-prev{left:16px;}.lb-next{right:16px;}
  .lb-bar{flex-shrink:0;display:flex;align-items:center;justify-content:space-between;gap:16px;padding:14px 24px;background:rgba(26,24,20,.7);border-top:1px solid rgba(244,237,224,.08);backdrop-filter:blur(12px);}
  .lb-bar-info{display:flex;flex-direction:column;gap:2px;min-width:0;}
  .lb-bar-id{font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:var(--gold-2);}
  .lb-bar-title{font-size:.78rem;color:rgba(244,237,224,.6);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;}
  .lb-bar-actions{display:flex;gap:8px;flex-shrink:0;}
  .lb-action{display:flex;align-items:center;gap:6px;padding:9px 14px;border:1px solid rgba(244,237,224,.18);background:transparent;color:var(--ivory);font-size:.6rem;letter-spacing:.14em;text-transform:uppercase;text-decoration:none;white-space:nowrap;transition:background .2s,border-color .2s,color .2s;}
  .lb-action:hover{background:rgba(244,237,224,.1);border-color:rgba(244,237,224,.3);}
  .lb-action.active{background:var(--gold);color:var(--teal-deep);border-color:var(--gold);}
  .lb-action-print{border-color:rgba(184,150,90,.5);color:var(--gold-2);}
  .lb-action-print:hover{background:rgba(184,150,90,.14);border-color:var(--gold);}

  .print-banner{display:flex;align-items:center;gap:20px;padding:18px 24px;margin-bottom:36px;background:linear-gradient(135deg,rgba(29,89,89,.06),rgba(184,150,90,.08));border:1px solid rgba(184,150,90,.22);position:relative;overflow:hidden;}
  .print-banner::before{content:'';position:absolute;left:0;top:0;bottom:0;width:3px;background:var(--gold);}
  .print-banner-icon{flex-shrink:0;width:44px;height:44px;display:grid;place-items:center;background:rgba(184,150,90,.1);border:1px solid rgba(184,150,90,.2);color:var(--gold);}
  .print-banner-text{flex:1;min-width:0;}
  .print-banner-text strong{display:block;font-family:var(--serif);font-size:1.1rem;font-weight:400;color:var(--ink);margin-bottom:2px;}
  .print-banner-text span{font-size:.76rem;color:var(--mist);letter-spacing:.02em;}
  .print-banner-cart{display:flex;align-items:center;gap:10px;flex-shrink:0;}
  .print-cart-pill{padding:8px 14px;background:var(--gold);color:var(--teal-deep);font-size:.6rem;letter-spacing:.16em;text-transform:uppercase;border:0;transition:background .2s;}
  .print-cart-pill:hover{background:var(--gold-2);}
  .print-cart-pill.empty{background:transparent;border:1px solid var(--line);color:var(--mist);}

  .print-add-btn{background:rgba(184,150,90,.15)!important;border-color:rgba(184,150,90,.4)!important;color:var(--gold-2)!important;}
  .print-add-btn:hover{background:rgba(184,150,90,.3)!important;}

  .print-overlay{position:fixed;inset:0;z-index:400;background:rgba(15,14,12,.6);display:none;align-items:center;justify-content:center;padding:24px;backdrop-filter:blur(4px);}
  .print-overlay.open{display:flex;}
  .print-panel{width:min(540px,100%);max-height:88vh;background:var(--paper);display:flex;flex-direction:column;box-shadow:0 30px 80px rgba(0,0,0,.3);}
  .print-panel-head{padding:24px 28px 20px;border-bottom:1px solid var(--line);display:flex;justify-content:space-between;align-items:flex-start;gap:16px;}
  .print-panel-title{font-family:var(--serif);font-size:1.8rem;font-weight:300;line-height:1.1;}
  .print-panel-close{width:36px;height:36px;border:1px solid var(--line);background:transparent;color:var(--ink);flex-shrink:0;}
  .print-panel-body{padding:24px 28px;overflow-y:auto;flex:1;}
  .print-cart-list{display:grid;gap:14px;margin-bottom:20px;}
  .print-cart-item{display:grid;grid-template-columns:68px 1fr auto;gap:14px;align-items:start;padding:14px;background:var(--ivory);border:1px solid var(--line-2);}
  .print-cart-item img{width:68px;height:52px;object-fit:cover;display:block;}
  .print-cart-item-info{min-width:0;}
  .print-cart-item-id{font-family:var(--serif);font-size:1rem;font-weight:400;}
  .print-cart-size-row{display:flex;gap:6px;margin-top:8px;}
  .print-size-btn{padding:6px 12px;border:1px solid var(--line);background:var(--ivory);color:var(--ink-soft);font-size:.62rem;letter-spacing:.12em;text-transform:uppercase;transition:all .2s;}
  .print-size-btn.active{background:var(--teal);border-color:var(--teal);color:var(--ivory);}
  .print-size-btn:hover:not(.active){border-color:var(--teal);color:var(--teal);}
  .print-qty-row{display:flex;align-items:center;gap:8px;margin-top:8px;}
  .print-qty-btn{width:28px;height:28px;border:1px solid var(--line);background:var(--ivory);color:var(--ink);font-size:.9rem;display:grid;place-items:center;}
  .print-qty-val{font-size:.82rem;min-width:20px;text-align:center;}
  .print-cart-price{font-family:var(--serif);font-size:1.1rem;color:var(--teal);white-space:nowrap;}
  .print-cart-remove{width:28px;height:28px;border:1px solid var(--line);background:transparent;color:var(--mist);font-size:.7rem;margin-top:6px;}
  .print-add-more{width:100%;padding:14px;border:1px dashed var(--line);background:transparent;color:var(--mist);font-size:.72rem;letter-spacing:.14em;text-transform:uppercase;transition:border-color .2s,color .2s;margin-bottom:24px;}
  .print-add-more:hover{border-color:var(--teal);color:var(--teal);}
  .print-subtotal{padding:14px 0;border-top:1px solid var(--line);border-bottom:1px solid var(--line);display:flex;justify-content:space-between;font-family:var(--serif);font-size:1.2rem;margin-bottom:24px;}
  .print-subtotal span{color:var(--teal);}
  .print-form-fields{display:grid;gap:12px;margin-bottom:20px;}
  .print-input{width:100%;padding:13px 14px;border:1px solid var(--line);background:var(--ivory);color:var(--ink);font-family:var(--sans);font-size:.88rem;line-height:1.5;}
  .print-input:focus{outline:1px solid var(--teal);border-color:var(--teal);}
  .print-textarea{min-height:80px;resize:vertical;}
  .print-panel-foot{padding:18px 28px;border-top:1px solid var(--line);display:grid;gap:10px;}
  .print-note{font-size:.7rem;color:var(--mist);text-align:center;line-height:1.6;}
  .print-wa-btn{display:flex;align-items:center;justify-content:center;gap:8px;}
  .print-success{display:none;text-align:center;padding:48px 24px;}
  .print-success.visible{display:block;}
  .print-success-icon{font-size:2.4rem;margin-bottom:16px;}
  .print-success h3{font-family:var(--serif);font-size:1.6rem;font-weight:300;margin-bottom:8px;}
  .print-success p{color:var(--mist);font-size:.86rem;line-height:1.7;}
  .print-empty{text-align:center;padding:32px 16px;color:var(--mist);font-size:.86rem;line-height:1.7;}

  .delivery-info{padding:90px 56px;background:var(--ink);color:var(--ivory);}
  .delivery-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1px;background:rgba(244,237,224,.14);margin-top:44px;}
  .delivery-card{background:var(--ink);padding:34px 30px;}
  .delivery-card h3{font-family:var(--serif);font-size:1.35rem;font-weight:400;margin-bottom:10px;color:var(--gold-2);}
  .delivery-card p{font-size:.84rem;line-height:1.8;color:rgba(244,237,224,.66);}

  @media(max-width:980px){
    .topbar{position:relative;padding:14px 20px;align-items:flex-start;display:grid;grid-template-columns:1fr;gap:16px;}
    .topbar img{height:38px;}
    .gallery-nav{gap:18px;flex-wrap:wrap;}
    .hero{grid-template-columns:1fr;padding:80px 24px 48px;gap:38px;min-height:0;}
    .hero-frame{min-height:360px;}
    .hero-photo.small{left:auto;right:18px;width:46%;height:34%;}
    .hero-meta{display:grid;grid-template-columns:1fr 1fr;}
    .toolbar{top:0;padding:16px 20px;align-items:flex-start;flex-direction:column;}
    .toolbar-tools{width:100%;display:grid;grid-template-columns:1fr;}
    .search,.sort-select{width:100%;min-width:0;}
    .gallery-wrap{padding:60px 20px 90px;}
    .section-head{display:block;}
    .section-note{margin-top:18px;}
    .photo-grid{columns:2 160px;column-gap:12px;}
    .photo-card,.quote-card{margin-bottom:12px;}
    .delivery-info{padding:70px 24px;}
    .delivery-grid{grid-template-columns:1fr;}
    .lock-panel{padding:40px 28px;}
    .lock-form{grid-template-columns:1fr;}
    .print-banner{flex-wrap:wrap;padding:16px 18px;gap:14px;}
    .print-banner-icon{width:36px;height:36px;}
    .print-banner-text strong{font-size:1rem;}
    .print-banner-cart{width:100%;}
    .print-cart-pill{width:100%;text-align:center;}
    .lb-bar{flex-direction:column;align-items:stretch;padding:12px 16px;gap:10px;}
    .lb-bar-actions{justify-content:stretch;}
    .lb-action{flex:1;justify-content:center;padding:10px 8px;font-size:.55rem;}
    .print-panel{max-height:94vh;}
    .print-cart-item{grid-template-columns:56px 1fr auto;}
    .print-cart-item img{width:56px;height:44px;}
  }
  @media(max-width:560px){
    .topbar{display:block;}
    .gallery-nav{margin-top:14px;}
    .top-actions{margin-top:14px;justify-content:flex-start;}
    .btn{width:100%;}
    .top-actions .btn,.top-actions .selection-pill{width:auto;}
    .hero-meta{grid-template-columns:1fr;}
    .photo-grid{columns:1;}
    .selected-item{grid-template-columns:66px 1fr auto;}
    .selected-item img{width:66px;height:54px;}
    .lb-action span{display:none;}
  }
</style>
</head>
<body>
<div class="screen-lock" id="screenLock">
  <div class="lock-panel">
    <img src="/assets/logo/logo-white.png" class="lock-logo" alt="Memorygraph Wedding Studio"/>
    <div class="lock-label">Private Client Gallery</div>
    <h1 class="lock-title">Your memories,<br><em>kept quietly.</em></h1>
    <p class="lock-copy">{{ lock_copy or "Enter the gallery password to view, download, and shortlist photographs for your wedding album." }}</p>
    <form class="lock-form" id="lockForm">
      <input type="password" id="passwordInput" placeholder="Gallery password" autocomplete="current-password" required/>
      <button class="btn gold" type="submit">Unlock</button>
    </form>
    <p class="lock-error" id="lockError">That password does not match this gallery.</p>
  </div>
</div>

<main class="gallery-app" id="galleryApp" aria-hidden="true">
  <header class="topbar">
    <a href="/" aria-label="Memorygraph home"><img src="/assets/logo/logo-dark.png" alt="Memorygraph Wedding Studio"/></a>
    <ul class="gallery-nav" aria-label="Gallery navigation">
      <li><a href="/">Home</a></li>
      <li><a href="/stories/">Stories</a></li>
      <li><a href="/investment/">Investment</a></li>
      <li><a href="/contact/">Contact</a></li>
    </ul>
    <div class="top-actions">
      <span class="selection-pill"><span id="selectionCount">0</span> selected</span>
      <button class="btn ghost" type="button" id="openDrawer">Album Picks</button>
      <button class="btn ghost" type="button" id="downloadAll">Download All</button>
      <button class="btn" type="button" id="lockAgain">Lock</button>
    </div>
  </header>

  <section class="hero">
    <div class="hero-copy">
      <div class="eyebrow">{{ couple_names or title }}</div>
      <h1>{{ hero_title | safe }}</h1>
      <p class="hero-sub">{{ intro }}</p>
      <div class="hero-meta">
        <div class="meta-item"><span class="meta-value" id="imageTotal">0</span><span class="meta-label">Images</span></div>
        <div class="meta-item"><span class="meta-value">Unlimited</span><span class="meta-label">Album Picks</span></div>
        <div class="meta-item"><span class="meta-value">{{ film_quality or "4K" }}</span><span class="meta-label">Film Delivery</span></div>
        <div class="meta-item"><span class="meta-value">Private</span><span class="meta-label">Password Gallery</span></div>
      </div>
    </div>
    <div class="hero-frame" aria-hidden="true">
      <div class="hero-photo"></div>
      <div class="hero-photo small"></div>
    </div>
  </section>

  <section class="toolbar" aria-label="Gallery filters">
    <div class="filters" id="filters">
      <button class="filter-btn active" type="button" data-filter="all">All</button>
      <button class="filter-btn" type="button" data-filter="selected">Selected</button>
    </div>
    <div class="toolbar-tools">
      <select class="sort-select" id="sortSelect" aria-label="Sort gallery">
        <option value="cms">CMS Order</option>
        <option value="selected">Selected First</option>
        <option value="code">Image Code</option>
        <option value="name">Image Name</option>
      </select>
      <input class="search" type="search" id="searchInput" placeholder="Search image code, name, or quote"/>
    </div>
  </section>

  <section class="gallery-wrap">
    <div class="section-head">
      <div>
        <div class="eyebrow">Choose for album</div>
        <h2 class="section-title">{{ selection_title | safe }}</h2>
      </div>
      <p class="section-note">{{ selection_note }}</p>
    </div>
    <div class="print-banner" id="printBanner">
      <div class="print-banner-icon">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><rect x="2" y="2" width="20" height="20" rx="1"/><rect x="5" y="5" width="14" height="14"/><path d="M2 2l3 3M22 2l-3 3M2 22l3-3M22 22l-3-3"/></svg>
      </div>
      <div class="print-banner-text">
        <strong>Print & frame service</strong>
        <span>A4 &#8212; &#8377;500 &middot; A3 &#8212; &#8377;1,000 &middot; Delivered to your door</span>
      </div>
      <div class="print-banner-cart">
        <button class="print-cart-pill empty" type="button" id="openPrintCart">
          <span id="printCartBadge">0</span> items &middot; View order
        </button>
      </div>
    </div>
    <div class="photo-grid" id="photoGrid"></div>
  </section>

  <section class="delivery-info">
    <div class="eyebrow">Delivery Included</div>
    <h2 class="section-title" style="color:var(--ivory);max-width:760px;">Everything arrives in one calm, private place.</h2>
    <div class="delivery-grid">
      <div class="delivery-card"><h3>Private gallery</h3><p>Password protected viewing for the couple and family, with organized moments instead of confusing folders.</p></div>
      <div class="delivery-card"><h3>Album selection</h3><p>Clients can shortlist any number of favorite images, add layout notes, and send the final image codes to Memorygraph.</p></div>
      <div class="delivery-card"><h3>CMS managed</h3><p>Each gallery can be created from the CMS with sortable image and quote blocks, custom labels, and its own password.</p></div>
    </div>
  </section>
</main>

<aside class="album-drawer" id="albumDrawer" aria-label="Album selections">
  <div class="drawer-head">
    <div><div class="eyebrow">Album Shortlist</div><h2 class="drawer-title">Selected images</h2></div>
    <button class="drawer-close" type="button" id="closeDrawer" aria-label="Close album picks">x</button>
  </div>
  <div class="drawer-body"><div class="selected-list" id="selectedList"></div></div>
  <div class="drawer-foot">
    <label class="textarea-label" for="selectorName">Your name</label>
    <input class="selector-name" id="selectorName" type="text" placeholder="Name of the person selecting album images" autocomplete="name" required/>
    <label class="textarea-label" for="albumNotes">Notes for album design</label>
    <textarea class="notes" id="albumNotes" placeholder="Example: Keep more candid moments, include parents on the opening spread, avoid too many posed portraits."></textarea>
    <button class="btn gold" type="button" id="copySelection">Copy Selection</button>
    <a class="btn" id="whatsappSelection" href="#" target="_blank" rel="noopener">Send on WhatsApp</a>
    <button class="btn ghost" type="button" id="downloadSelected">Download Selected</button>
    <button class="btn ghost" type="button" id="clearSelection">Clear Picks</button>
    <div class="export-output" id="exportOutput"></div>
  </div>
</aside>

<div class="lightbox" id="galleryLightbox" aria-hidden="true">
  <div class="lb-stage">
    <button class="lb-close" type="button" id="lbClose" aria-label="Close">&times;</button>
    <button class="lb-prev" type="button" id="lbPrev" aria-label="Previous">&#8249;</button>
    <button class="lb-next" type="button" id="lbNext" aria-label="Next">&#8250;</button>
    <img src="" alt="" id="lbImage"/>
  </div>
  <div class="lb-bar">
    <div class="lb-bar-info">
      <span class="lb-bar-id" id="lbBarId"></span>
      <span class="lb-bar-title" id="lbBarTitle"></span>
    </div>
    <div class="lb-bar-actions">
      <button class="lb-action" type="button" id="lbSelect">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>
        <span>Select</span>
      </button>
      <a class="lb-action" id="lbDownload" href="#" download>
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 3v12M7 10l5 5 5-5"/><path d="M5 20h14"/></svg>
        <span>Download</span>
      </a>
      <button class="lb-action lb-action-print" type="button" id="lbOrderPrint">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><rect x="2" y="2" width="20" height="20" rx="1"/><rect x="5" y="5" width="14" height="14"/><path d="M2 2l3 3M22 2l-3 3M2 22l3-3M22 22l-3-3"/></svg>
        <span>Order Print</span>
      </button>
    </div>
  </div>
</div>

<div class="print-overlay" id="printOverlay">
  <div class="print-panel">
    <div class="print-panel-head">
      <div>
        <div class="eyebrow">Print & Frame</div>
        <div class="print-panel-title">Your print order</div>
      </div>
      <button class="print-panel-close" type="button" id="closePrintPanel">&times;</button>
    </div>
    <div class="print-panel-body" id="printPanelBody">
      <div class="print-cart-list" id="printCartList"></div>
      <button class="print-add-more" type="button" id="printAddMore">+ Add another photo</button>
      <div class="print-subtotal" id="printSubtotal">Order total <span>&#8377;0</span></div>
      <div class="eyebrow" style="margin-bottom:14px;">Delivery details</div>
      <div class="print-form-fields">
        <input class="print-input" type="text" id="printName" placeholder="Full name" required/>
        <input class="print-input" type="tel" id="printPhone" placeholder="Phone number" required/>
        <textarea class="print-input print-textarea" id="printAddress" placeholder="Delivery address (with PIN code)"></textarea>
      </div>
    </div>
    <div class="print-panel-foot">
      <button class="btn gold" type="button" id="submitPrintOrder" style="width:100%;">Place Order</button>
      <a class="btn ghost print-wa-btn" id="printWhatsApp" href="#" target="_blank" rel="noopener">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.5 14.4l-2-1c-.3-.1-.5-.1-.7.2l-.9 1.1c-.2.2-.3.2-.6.1-1.7-.8-2.8-1.8-3.7-3.1-.2-.3-.1-.5.1-.7l.6-.7c.2-.2.2-.4.1-.6l-1-2.3c-.2-.6-.5-.5-.7-.5h-.6c-.2 0-.6.1-.9.4C6.5 8 6 9 6 10.1s1 2.7 1.1 2.9c.1.2 2 3.1 4.9 4.3 2 .8 2.8.9 3.8.8.6-.1 1.9-.8 2.2-1.5.3-.8.3-1.4.2-1.5-.1-.2-.3-.3-.7-.5zM12 2C6.5 2 2 6.5 2 12c0 1.8.5 3.5 1.4 5L2 22l5.2-1.4c1.4.8 3 1.2 4.8 1.2 5.5 0 10-4.5 10-10S17.5 2 12 2z"/></svg>
        Send via WhatsApp
      </a>
      <p class="print-note">No payment required now. We will confirm your order and arrange delivery.</p>
    </div>
    <div class="print-success" id="printSuccess">
      <div class="print-success-icon">&#10003;</div>
      <h3>Order placed</h3>
      <p>Your print order has been received. We will contact you shortly to confirm the details and delivery.</p>
      <button class="btn ghost" type="button" id="printSuccessClose" style="margin-top:24px;">Back to gallery</button>
    </div>
  </div>
</div>

<script>
  const galleryPassword = {{ password | json | safe }};
  const gallerySlug = {{ page.fileSlug | json | safe }};
  const galleryTitle = {{ title | json | safe }};
  const coupleNames = {{ (couple_names or title) | json | safe }};
  const whatsappNumber = {{ (whatsapp_number or "919846238073") | json | safe }};
  const galleryItems = {{ gallery_items | clientGalleryItems(gallery_folder) | json | safe }};
  const authKey = `memorygraph_gallery_unlocked_${gallerySlug}`;
  const storageKey = `memorygraph_album_selection_${gallerySlug}`;
  const notesKey = `memorygraph_album_notes_${gallerySlug}`;
  const selectorNameKey = `memorygraph_album_selector_${gallerySlug}`;
  let selected = new Set(JSON.parse(localStorage.getItem(storageKey) || '[]'));
  let activeFilter = 'all';
  let sortMode = 'cms';
  let renderedImages = [];
  let lightboxIndex = 0;

  const imageItems = galleryItems
    .map((item, index) => ({...item, order:index, item_type:item.item_type || (item.image ? 'image' : 'quote')}))
    .filter(item => item.item_type === 'image' && item.image)
    .map((item, index) => ({
      id: item.image_code || `MG-${String(index + 1).padStart(3, '0')}`,
      src: item.image,
      cat: (item.category || 'gallery').toLowerCase(),
      title: item.image_name || item.caption || `Image ${index + 1}`,
      caption: item.caption || '',
      order: item.order
    }));

  const screenLock = document.getElementById('screenLock');
  const galleryApp = document.getElementById('galleryApp');
  const photoGrid = document.getElementById('photoGrid');
  const selectionCount = document.getElementById('selectionCount');
  const selectedList = document.getElementById('selectedList');
  const albumDrawer = document.getElementById('albumDrawer');
  const selectorName = document.getElementById('selectorName');
  const albumNotes = document.getElementById('albumNotes');
  const exportOutput = document.getElementById('exportOutput');
  const whatsappSelection = document.getElementById('whatsappSelection');

  document.getElementById('imageTotal').textContent = imageItems.length;
  selectorName.value = localStorage.getItem(selectorNameKey) || '';
  albumNotes.value = localStorage.getItem(notesKey) || '';

  function unlockGallery(){
    screenLock.classList.add('hidden');
    galleryApp.setAttribute('aria-hidden','false');
    sessionStorage.setItem(authKey,'true');
  }

  if(sessionStorage.getItem(authKey) === 'true') unlockGallery();

  document.getElementById('lockForm').addEventListener('submit', (event) => {
    event.preventDefault();
    const input = document.getElementById('passwordInput');
    const error = document.getElementById('lockError');
    if(input.value.trim() === String(galleryPassword || '').trim()){
      error.classList.remove('visible');
      unlockGallery();
    } else {
      error.classList.add('visible');
      input.select();
    }
  });

  document.getElementById('lockAgain').addEventListener('click', () => {
    sessionStorage.removeItem(authKey);
    screenLock.classList.remove('hidden');
    galleryApp.setAttribute('aria-hidden','true');
  });

  function saveSelection(){
    localStorage.setItem(storageKey, JSON.stringify([...selected]));
  }

  function addCategoryFilters(){
    const filters = document.getElementById('filters');
    const categories = [...new Set(imageItems.map(image => image.cat).filter(Boolean))].sort();
    categories.forEach(category => {
      const button = document.createElement('button');
      button.className = 'filter-btn';
      button.type = 'button';
      button.dataset.filter = category;
      button.textContent = category.replace(/-/g, ' ');
      filters.insertBefore(button, filters.querySelector('[data-filter="selected"]'));
    });
  }

  function sortedGalleryItems(){
    const normalized = galleryItems.map((item, index) => ({...item, order:index, item_type:item.item_type || (item.image ? 'image' : 'quote')}));
    if(sortMode === 'cms') return normalized;
    return [...normalized].sort((a, b) => {
      const aId = a.image_code || '';
      const bId = b.image_code || '';
      if(sortMode === 'selected') return Number(selected.has(bId)) - Number(selected.has(aId)) || a.order - b.order;
      if(sortMode === 'code') return aId.localeCompare(bId) || a.order - b.order;
      if(sortMode === 'name') return (a.image_name || a.caption || a.quote || '').localeCompare(b.image_name || b.caption || b.quote || '') || a.order - b.order;
      return a.order - b.order;
    });
  }

  function buildGallery(){
    const items = sortedGalleryItems();
    renderedImages = [];
    photoGrid.innerHTML = items.map((item) => {
      const type = item.item_type || (item.image ? 'image' : 'quote');
      if(type === 'quote'){
        return `<article class="quote-card" data-type="quote" data-title="${escapeAttr(item.quote || '')}">
          <blockquote>${escapeHtml(item.quote || '')}</blockquote>
          ${item.quote_by ? `<cite>${escapeHtml(item.quote_by)}</cite>` : ''}
        </article>`;
      }
      const imageIndex = renderedImages.length;
      const id = item.image_code || `MG-${String(imageIndex + 1).padStart(3, '0')}`;
      const image = {
        id,
        src: item.image,
        cat: (item.category || 'gallery').toLowerCase(),
        title: item.image_name || item.caption || `Image ${imageIndex + 1}`,
        caption: item.caption || '',
        order: item.order
      };
      renderedImages.push(image);
      return `<article class="photo-card${selected.has(image.id) ? ' selected' : ''}" data-type="image" data-id="${escapeAttr(image.id)}" data-cat="${escapeAttr(image.cat)}" data-title="${escapeAttr((image.title + ' ' + image.caption).toLowerCase())}">
        <img src="${escapeAttr(image.src)}" alt="${escapeAttr(image.title)}" loading="lazy"/>
        <div class="photo-overlay">
          <span class="photo-id">${escapeHtml(image.id)} · ${escapeHtml(image.title)}</span>
          <div class="photo-controls">
            <button class="icon-btn view-btn" type="button" data-index="${imageIndex}" aria-label="View ${escapeAttr(image.id)}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M2 12s3.5-6 10-6 10 6 10 6-3.5 6-10 6-10-6-10-6z"/><circle cx="12" cy="12" r="3"/></svg>
            </button>
            <a class="icon-btn download-btn" href="${escapeAttr(image.src)}" download="${escapeAttr(fileNameForImage(image))}" aria-label="Download ${escapeAttr(image.id)}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.7"><path d="M12 3v12M7 10l5 5 5-5"/><path d="M5 20h14"/></svg>
            </a>
            <button class="icon-btn select-btn" type="button" data-id="${escapeAttr(image.id)}" aria-label="Select ${escapeAttr(image.id)}">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 6L9 17l-5-5"/></svg>
            </button>
            <button class="icon-btn print-add-btn" type="button" data-index="${imageIndex}" aria-label="Order print of ${escapeAttr(image.id)}">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><rect x="2" y="2" width="20" height="20" rx="1"/><rect x="5" y="5" width="14" height="14"/><path d="M2 2l3 3M22 2l-3 3M2 22l3-3M22 22l-3-3"/></svg>
            </button>
          </div>
        </div>
      </article>`;
    }).join('');
    photoGrid.querySelectorAll('.select-btn').forEach(button => button.addEventListener('click', (e) => { e.stopPropagation(); toggleSelect(button.dataset.id); }));
    photoGrid.querySelectorAll('.view-btn').forEach(button => button.addEventListener('click', (e) => { e.stopPropagation(); openLightbox(Number(button.dataset.index)); }));
    photoGrid.querySelectorAll('.download-btn').forEach(link => link.addEventListener('click', (e) => e.stopPropagation()));
    photoGrid.querySelectorAll('.print-add-btn').forEach(button => button.addEventListener('click', (e) => { e.stopPropagation(); addToPrintCart(renderedImages[Number(button.dataset.index)]); }));
    photoGrid.querySelectorAll('.photo-card').forEach(card => {
      card.addEventListener('click', () => {
        const idx = renderedImages.findIndex(img => img.id === card.dataset.id);
        if (idx >= 0) openLightbox(idx);
      });
      card.style.cursor = 'pointer';
    });
    applyFilters();
  }

  function toggleSelect(id){
    if(selected.has(id)) selected.delete(id);
    else selected.add(id);
    saveSelection();
    renderSelection();
    document.querySelectorAll(`[data-id="${cssEscape(id)}"]`).forEach(card => card.classList.toggle('selected', selected.has(id)));
    if(sortMode === 'selected') buildGallery();
    else applyFilters();
  }

  function renderSelection(){
    selectionCount.textContent = selected.size;
    const chosen = imageItems.filter(image => selected.has(image.id));
    selectedList.innerHTML = chosen.length ? chosen.map(image => `
      <div class="selected-item">
        <img src="${escapeAttr(image.src)}" alt="${escapeAttr(image.title)}"/>
        <div><strong>${escapeHtml(image.id)}</strong><span>${escapeHtml(image.title)}</span></div>
        <button class="mini-remove" type="button" data-id="${escapeAttr(image.id)}" aria-label="Remove ${escapeAttr(image.id)}">x</button>
      </div>
    `).join('') : '<p style="font-size:.88rem;line-height:1.8;color:var(--ink-soft);">No images selected yet. Choose the frames you want in the album, then come back here to review them.</p>';
    selectedList.querySelectorAll('.mini-remove').forEach(button => button.addEventListener('click', () => toggleSelect(button.dataset.id)));
    updateShareLinks();
  }

  function applyFilters(){
    const search = document.getElementById('searchInput').value.trim().toLowerCase();
    document.querySelectorAll('.photo-card,.quote-card').forEach((card) => {
      const type = card.dataset.type;
      const matchesFilter = activeFilter === 'all' || (activeFilter === 'selected' && selected.has(card.dataset.id)) || card.dataset.cat === activeFilter || (activeFilter !== 'selected' && type === 'quote');
      const matchesSearch = !search || (card.dataset.id || '').toLowerCase().includes(search) || (card.dataset.title || '').includes(search);
      card.classList.toggle('hidden', !(matchesFilter && matchesSearch));
    });
  }

  document.getElementById('filters').addEventListener('click', (event) => {
    const button = event.target.closest('.filter-btn');
    if(!button) return;
    document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
    button.classList.add('active');
    activeFilter = button.dataset.filter;
    applyFilters();
  });

  document.getElementById('searchInput').addEventListener('input', applyFilters);
  document.getElementById('sortSelect').addEventListener('change', (event) => {
    sortMode = event.target.value;
    buildGallery();
  });
  document.getElementById('openDrawer').addEventListener('click', () => albumDrawer.classList.add('open'));
  document.getElementById('closeDrawer').addEventListener('click', () => albumDrawer.classList.remove('open'));
  selectorName.addEventListener('input', () => {
    localStorage.setItem(selectorNameKey, selectorName.value);
    updateShareLinks();
  });
  albumNotes.addEventListener('input', () => {
    localStorage.setItem(notesKey, albumNotes.value);
    updateShareLinks();
  });

  function selectionText(){
    const codes = [...selected];
    const selectedBy = selectorName.value.trim();
    const notes = albumNotes.value.trim();
    return `Memorygraph album selection - ${coupleNames}\nGallery: ${galleryTitle}\nSelected by: ${selectedBy || 'Not provided'}\n\nSelected images (${codes.length}):\n${codes.length ? codes.join(', ') : 'None yet'}\n\nNotes:\n${notes || 'No notes added.'}`;
  }

  function requireSelectorName(){
    if(selectorName.value.trim()) return true;
    albumDrawer.classList.add('open');
    selectorName.focus();
    exportOutput.textContent = 'Please enter the name of the person selecting the album images before sending the selection.';
    exportOutput.classList.add('visible');
    return false;
  }

  function updateShareLinks(){
    const text = encodeURIComponent(selectionText());
    whatsappSelection.href = `https://wa.me/${whatsappNumber}?text=${text}`;
  }

  document.getElementById('copySelection').addEventListener('click', async () => {
    if(!requireSelectorName()) return;
    const text = selectionText();
    try {
      await navigator.clipboard.writeText(text);
      exportOutput.textContent = 'Copied to clipboard:\n\n' + text;
    } catch (error) {
      exportOutput.textContent = text;
    }
    exportOutput.classList.add('visible');
  });

  whatsappSelection.addEventListener('click', (event) => {
    if(!requireSelectorName()) event.preventDefault();
  });

  document.getElementById('downloadAll').addEventListener('click', () => {
    downloadImages(imageItems, 'Starting download for the full gallery. Your browser may ask permission for multiple files.');
  });

  document.getElementById('downloadSelected').addEventListener('click', () => {
    const chosen = imageItems.filter(image => selected.has(image.id));
    if(!chosen.length){
      exportOutput.textContent = 'Select at least one image before downloading selected images.';
      exportOutput.classList.add('visible');
      return;
    }
    downloadImages(chosen, `Starting download for ${chosen.length} selected image${chosen.length === 1 ? '' : 's'}.`);
  });

  document.getElementById('clearSelection').addEventListener('click', () => {
    selected = new Set();
    saveSelection();
    buildGallery();
    renderSelection();
    exportOutput.textContent = 'Album picks cleared on this device.';
    exportOutput.classList.add('visible');
  });

  const lightbox = document.getElementById('galleryLightbox');
  const lbImage = document.getElementById('lbImage');
  const lbBarId = document.getElementById('lbBarId');
  const lbBarTitle = document.getElementById('lbBarTitle');
  const lbSelectBtn = document.getElementById('lbSelect');
  const lbDownloadBtn = document.getElementById('lbDownload');
  const lbOrderPrintBtn = document.getElementById('lbOrderPrint');

  function openLightbox(index){
    lightboxIndex = index;
    updateLightbox();
    lightbox.classList.add('open');
    lightbox.setAttribute('aria-hidden','false');
    document.body.style.overflow = 'hidden';
  }

  function updateLightbox(){
    const image = renderedImages[lightboxIndex];
    if(!image) return;
    lbImage.src = image.src;
    lbImage.alt = image.title;
    lbBarId.textContent = image.id;
    lbBarTitle.textContent = image.title;
    lbSelectBtn.classList.toggle('active', selected.has(image.id));
    lbDownloadBtn.href = image.src;
    lbDownloadBtn.download = fileNameForImage(image);
  }

  function closeLightbox(){
    lightbox.classList.remove('open');
    lightbox.setAttribute('aria-hidden','true');
    document.body.style.overflow = '';
  }

  lbSelectBtn.addEventListener('click', () => {
    const image = renderedImages[lightboxIndex];
    if(image) toggleSelect(image.id);
    updateLightbox();
  });
  lbOrderPrintBtn.addEventListener('click', () => {
    const image = renderedImages[lightboxIndex];
    if(image) addToPrintCart(image);
  });

  document.getElementById('lbClose').addEventListener('click', closeLightbox);
  document.getElementById('lbPrev').addEventListener('click', () => { lightboxIndex = (lightboxIndex - 1 + renderedImages.length) % renderedImages.length; updateLightbox(); });
  document.getElementById('lbNext').addEventListener('click', () => { lightboxIndex = (lightboxIndex + 1) % renderedImages.length; updateLightbox(); });
  lightbox.querySelector('.lb-stage').addEventListener('click', event => { if(event.target === event.currentTarget || event.target === lbImage) closeLightbox(); });
  document.addEventListener('keydown', event => {
    if(!lightbox.classList.contains('open')) return;
    if(event.key === 'Escape') closeLightbox();
    if(event.key === 'ArrowLeft') document.getElementById('lbPrev').click();
    if(event.key === 'ArrowRight') document.getElementById('lbNext').click();
  });

  function escapeHtml(value){
    return String(value || '').replace(/[&<>"']/g, char => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#039;'}[char]));
  }

  function escapeAttr(value){
    return escapeHtml(value).replace(/`/g, '&#096;');
  }

  function fileNameForImage(image){
    const extMatch = String(image.src || '').split('?')[0].match(/\.[a-z0-9]+$/i);
    const ext = extMatch ? extMatch[0] : '.jpg';
    const safeTitle = String(image.title || 'image').toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    return `${image.id}-${safeTitle || 'image'}${ext}`;
  }

  function downloadImages(images, message){
    if(!images.length) return;
    exportOutput.textContent = message;
    exportOutput.classList.add('visible');
    images.forEach((image, index) => {
      setTimeout(() => {
        const link = document.createElement('a');
        link.href = image.src;
        link.download = fileNameForImage(image);
        link.rel = 'noopener';
        document.body.appendChild(link);
        link.click();
        link.remove();
      }, index * 180);
    });
  }

  function cssEscape(value){
    if(window.CSS && CSS.escape) return CSS.escape(value);
    return String(value).replace(/"/g, '\\"');
  }

  // ═══ PRINT CART ═══
  const printCartKey = `memorygraph_print_cart_${gallerySlug}`;
  let printCart = JSON.parse(localStorage.getItem(printCartKey) || '[]');
  const printOverlay = document.getElementById('printOverlay');
  const printCartList = document.getElementById('printCartList');
  const printSubtotal = document.getElementById('printSubtotal');
  const printCartBadge = document.getElementById('printCartBadge');
  const openPrintCartBtn = document.getElementById('openPrintCart');
  const printSuccess = document.getElementById('printSuccess');
  const printPanelBody = document.getElementById('printPanelBody');

  function savePrintCart(){
    localStorage.setItem(printCartKey, JSON.stringify(printCart));
    updatePrintBadge();
  }

  function updatePrintBadge(){
    const count = printCart.reduce((s, i) => s + (i.qty || 1), 0);
    printCartBadge.textContent = count;
    openPrintCartBtn.classList.toggle('empty', count === 0);
  }

  function addToPrintCart(image){
    const existing = printCart.find(i => i.imageId === image.id);
    if(existing){
      existing.qty = (existing.qty || 1) + 1;
    } else {
      printCart.push({ imageId: image.id, src: image.src, title: image.title, size: 'A4', qty: 1 });
    }
    savePrintCart();
    openPrintPanel();
  }

  function getPrintTotal(){
    return printCart.reduce((sum, item) => sum + (item.size === 'A3' ? 1000 : 500) * (item.qty || 1), 0);
  }

  function renderPrintCart(){
    if(!printCart.length){
      printCartList.innerHTML = '<div class="print-empty">No items yet. Click the frame icon on any photo, or use the <strong>Order Print</strong> button in the fullscreen view.</div>';
    } else {
      printCartList.innerHTML = printCart.map((item, idx) => `
        <div class="print-cart-item">
          <img src="${escapeAttr(item.src)}" alt="${escapeAttr(item.title)}"/>
          <div class="print-cart-item-info">
            <div class="print-cart-item-id">${escapeHtml(item.imageId)}</div>
            <div class="print-cart-size-row">
              <button class="print-size-btn${item.size === 'A4' ? ' active' : ''}" type="button" data-idx="${idx}" data-size="A4">A4 &middot; &#8377;500</button>
              <button class="print-size-btn${item.size === 'A3' ? ' active' : ''}" type="button" data-idx="${idx}" data-size="A3">A3 &middot; &#8377;1,000</button>
            </div>
            <div class="print-qty-row">
              <button class="print-qty-btn" type="button" data-idx="${idx}" data-dir="-1">&minus;</button>
              <span class="print-qty-val">${item.qty || 1}</span>
              <button class="print-qty-btn" type="button" data-idx="${idx}" data-dir="1">+</button>
              <button class="print-cart-remove" type="button" data-idx="${idx}" title="Remove">&times;</button>
            </div>
          </div>
          <div class="print-cart-price">&#8377;${((item.size === 'A3' ? 1000 : 500) * (item.qty || 1)).toLocaleString('en-IN')}</div>
        </div>
      `).join('');
      printCartList.querySelectorAll('.print-size-btn').forEach(btn => btn.addEventListener('click', () => {
        printCart[Number(btn.dataset.idx)].size = btn.dataset.size;
        savePrintCart();
        renderPrintCart();
      }));
      printCartList.querySelectorAll('.print-qty-btn').forEach(btn => btn.addEventListener('click', () => {
        const idx = Number(btn.dataset.idx);
        const dir = Number(btn.dataset.dir);
        printCart[idx].qty = Math.max(1, (printCart[idx].qty || 1) + dir);
        savePrintCart();
        renderPrintCart();
      }));
      printCartList.querySelectorAll('.print-cart-remove').forEach(btn => btn.addEventListener('click', () => {
        printCart.splice(Number(btn.dataset.idx), 1);
        savePrintCart();
        renderPrintCart();
      }));
    }
    printSubtotal.innerHTML = `Order total <span>&#8377;${getPrintTotal().toLocaleString('en-IN')}</span>`;
    updatePrintWhatsApp();
  }

  function openPrintPanel(){
    printSuccess.classList.remove('visible');
    printPanelBody.style.display = '';
    document.querySelector('.print-panel-foot').style.display = '';
    renderPrintCart();
    printOverlay.classList.add('open');
  }

  function closePrintPanel(){
    printOverlay.classList.remove('open');
  }

  function printOrderText(){
    const name = document.getElementById('printName').value.trim();
    const phone = document.getElementById('printPhone').value.trim();
    const address = document.getElementById('printAddress').value.trim();
    let text = `Memorygraph Print Order\nGallery: ${galleryTitle}\n\n`;
    printCart.forEach(item => {
      text += `${item.imageId} — ${item.size} × ${item.qty || 1} — ₹${((item.size === 'A3' ? 1000 : 500) * (item.qty || 1))}\n`;
    });
    text += `\nTotal: ₹${getPrintTotal().toLocaleString('en-IN')}\n\nName: ${name || 'Not provided'}\nPhone: ${phone || 'Not provided'}\nAddress: ${address || 'Not provided'}`;
    return text;
  }

  function updatePrintWhatsApp(){
    const text = encodeURIComponent(printOrderText());
    document.getElementById('printWhatsApp').href = `https://wa.me/${whatsappNumber}?text=${text}`;
  }

  openPrintCartBtn.addEventListener('click', openPrintPanel);
  document.getElementById('closePrintPanel').addEventListener('click', closePrintPanel);
  printOverlay.addEventListener('click', e => { if(e.target === printOverlay) closePrintPanel(); });
  document.getElementById('printAddMore').addEventListener('click', () => { closePrintPanel(); });

  document.getElementById('submitPrintOrder').addEventListener('click', async () => {
    const name = document.getElementById('printName').value.trim();
    const phone = document.getElementById('printPhone').value.trim();
    const address = document.getElementById('printAddress').value.trim();
    if(!printCart.length){ alert('Add at least one photo to your order.'); return; }
    if(!name || !phone || !address){ alert('Please fill in your name, phone number, and delivery address.'); return; }
    const submitBtn = document.getElementById('submitPrintOrder');
    submitBtn.textContent = 'Placing order...';
    submitBtn.disabled = true;
    try {
      const res = await fetch('/api/order', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify({ gallery: galleryTitle, items: printCart, name, phone, address })
      });
      if(res.ok){
        printCart = [];
        savePrintCart();
        printPanelBody.style.display = 'none';
        document.querySelector('.print-panel-foot').style.display = 'none';
        printSuccess.classList.add('visible');
      } else {
        const err = await res.json().catch(() => ({}));
        alert(err.error || 'Order could not be placed. Please try sending via WhatsApp instead.');
      }
    } catch(e) {
      alert('Network error. Please try sending your order via WhatsApp instead.');
    }
    submitBtn.textContent = 'Place Order';
    submitBtn.disabled = false;
  });

  document.getElementById('printSuccessClose').addEventListener('click', closePrintPanel);

  document.querySelectorAll('#printName,#printPhone,#printAddress').forEach(el => el.addEventListener('input', updatePrintWhatsApp));

  updatePrintBadge();

  addCategoryFilters();
  buildGallery();
  renderSelection();
</script>
</body>
</html>
