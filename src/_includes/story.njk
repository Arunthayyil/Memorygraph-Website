<!DOCTYPE html>
<!--
═══════════════════════════════════════════════════════════════════════
WEDDING STORY TEMPLATE — Memorygraph Weddings
═══════════════════════════════════════════════════════════════════════

HOW TO USE THIS TEMPLATE:
1. Copy this file and rename to: stories/[couple-slug].html
   Example: stories/abhin-gayathry.html
2. Find every {{PLACEHOLDER}} below and replace with real content
3. Replace gallery images with real photo paths (assets/stories/[couple]/01.jpg etc)
4. Update prev/next links at the bottom to navigate between stories

PLACEHOLDERS YOU NEED TO FILL:
  Abhin &amp; Gayathry     — e.g. "Abhin & Gayathry"
  Gayathry, the bride     — e.g. "Abhin & Gayathry" (no last names, used in titles)
  Vadakkumnathan Temple, Thrissur         — e.g. "Vadakkumnathan Temple, Thrissur"
  Thrissur   — e.g. "Thrissur"
  15 November 2024             — e.g. "15 November 2024"
  2024             — e.g. "2024"
         — Path to hero image
  https://www.youtube.com/embed/dQw4w9WgXcQ         — YouTube embed URL (or leave empty to hide film section)
  {{NARRATIVE}}        — 2-3 paragraph story
  We barely felt the camera. Looking at the photographs now, it feels like the day was preserved exactly as we lived it.       — Quote from couple
  840      — e.g. "840"
  12   — e.g. "12"
  2    — e.g. "2"

═══════════════════════════════════════════════════════════════════════
-->
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>{{ title }} — A Wedding in {{ location_short }} | Memorygraph</title>
<meta name="description" content="A cinematic wedding story of {{ title }} at {{ location }}. Photographed and filmed by Memorygraph Wedding Studio."/>
<meta property="og:title" content='{{ title }} — A {{ location_short }} Wedding Story'/>
<meta property="og:image" content=""/>
<meta property="og:type" content="article"/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500&family=Jost:wght@200;300;400;500&display=swap" rel="stylesheet"/>
<style>
  *,*::before,*::after { margin:0; padding:0; box-sizing:border-box; }

  :root {
    --ivory:    #f4ede0;
    --ivory-2:  #ece4d4;
    --ink:      #1a1814;
    --ink-soft: #3a3530;
    --teal:     #1d5959;
    --teal-deep:#0f3838;
    --gold:     #b8965a;
    --gold-2:   #d4a96a;
    --mist:     #8b857a;
    --line:     rgba(26,24,20,.12);
    --line-2:   rgba(26,24,20,.06);
    --serif:    'Cormorant Garamond', Georgia, serif;
    --sans:     'Jost', sans-serif;
  }

  html { scroll-behavior:smooth; }
  body {
    background: var(--ivory);
    color: var(--ink);
    font-family: var(--sans);
    font-weight: 300;
    overflow-x: hidden;
    cursor: none;
  }

  body::before {
    content:''; position:fixed; inset:0; pointer-events:none; z-index:1;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 400 400' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.04'/%3E%3C/svg%3E");
    mix-blend-mode: multiply; opacity:.6;
  }

  input, textarea, select { cursor: text; }

  @media (prefers-reduced-motion: reduce) {
    body { cursor: auto; }
    .cursor { display: none; }
  }

  /* CURSOR */
  .cursor { position:fixed; top:0; left:0; z-index:9999; pointer-events:none; }
  .cursor-dot { width:4px; height:6px; background:var(--teal); border-radius:50%; position:absolute; transform:translate(-50%,-50%); }
  .cursor-ring { width:24px; height:36px; border:1px solid rgba(29,89,89,.4); border-radius:50%; position:absolute; transform:translate(-50%,-50%); transition:width .25s, height .25s; }

  /* NAV */
  nav {
    position:fixed; top:0; left:0; width:100%; z-index:100;
    padding:24px 56px; display:flex; align-items:center; justify-content:space-between;
    transition:padding .5s, background .5s;
  }
  nav.scrolled {
    padding:14px 56px;
    background: rgba(244,237,224,.92); backdrop-filter: blur(16px);
    border-bottom:1px solid var(--line-2);
  }
  .nav-logo { display:flex; align-items:center; gap:12px; text-decoration:none; color:var(--ink); }
  .nav-mark { width:30px; height:24px; }
  .nav-mark svg { width:100%; height:100%; }
  .nav-wordmark { font-family:var(--serif); font-size:1.15rem; font-weight:500; letter-spacing:.04em; line-height:1; }
  .nav-wordmark small { display:block; font-family:var(--sans); font-size:.55rem; letter-spacing:.32em; color:var(--mist); margin-top:4px; }
  .nav-links { display:flex; gap:42px; list-style:none; }
  .nav-links a { font-family:var(--sans); font-size:.7rem; letter-spacing:.22em; text-transform:uppercase; color:var(--ink-soft); text-decoration:none; transition:color .3s; position:relative; }
  .nav-links a::after { content:''; position:absolute; bottom:-4px; left:0; width:0; height:1px; background:var(--teal); transition:width .4s; }
  .nav-links a:hover, .nav-links a.active { color:var(--teal); }
  .nav-links a:hover::after, .nav-links a.active::after { width:100%; }
  .nav-cta { font-family:var(--sans); font-size:.7rem; letter-spacing:.22em; text-transform:uppercase; background:var(--teal); color:var(--ivory); padding:11px 26px; text-decoration:none; transition:all .35s; border:1px solid var(--teal); }
  .nav-cta:hover { background:var(--teal-deep); }

  /* ─────────────────────────────────────
     STORY HERO — Full-bleed cinematic image
     ───────────────────────────────────── */
  .story-hero {
    position: relative; width: 100%; height: 100vh; min-height: 700px;
    overflow: hidden;
  }
  .story-hero-img {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    background-color: #c9bda1;
  }
  .story-hero-img.placeholder {
    background: linear-gradient(160deg, #d8cfb8 0%, #b8a98a 50%, #a89a78 100%);
  }
  .story-hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(to bottom,
      rgba(26,24,20,.3) 0%,
      rgba(26,24,20,.1) 30%,
      rgba(26,24,20,.5) 100%);
  }
  .story-hero-content {
    position: absolute; bottom: 0; left: 0; right: 0;
    padding: 0 56px 80px;
    color: var(--ivory);
    z-index: 2;
  }
  .story-hero-eyebrow {
    font-family: var(--sans); font-size: .65rem; font-weight: 400;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--gold-2); margin-bottom: 28px;
    display: flex; align-items: center; gap: 14px;
    opacity: 0; animation: fadeUp .8s .3s forwards;
  }
  .story-hero-eyebrow::before { content:''; width:32px; height:1px; background:var(--gold-2); }
  .story-hero-name {
    font-family: var(--serif);
    font-size: clamp(4rem, 10vw, 11rem);
    font-weight: 300; line-height: .95;
    letter-spacing: -.02em;
    margin-bottom: 32px;
    opacity: 0; animation: fadeUp .9s .5s forwards;
  }
  .story-hero-name em { font-style: italic; color: var(--gold-2); }
  .story-hero-meta {
    display: flex; gap: 40px; flex-wrap: wrap;
    font-family: var(--sans); font-size: .72rem;
    letter-spacing: .25em; text-transform: uppercase;
    color: rgba(244,237,224,.85);
    opacity: 0; animation: fadeUp .9s .7s forwards;
  }
  .story-hero-meta-item { display: flex; align-items: center; gap: 12px; }
  .story-hero-meta-item::before { content: ''; width: 18px; height: 1px; background: var(--gold-2); }
  .story-hero-meta-item:first-child::before { display: none; }
  .story-hero-scroll {
    position: absolute; bottom: 32px; right: 56px; z-index: 2;
    color: var(--ivory);
    opacity: 0; animation: fadeIn 1s 1.2s forwards;
  }
  .story-hero-scroll-line {
    width: 1px; height: 50px; background: rgba(244,237,224,.4);
    position: relative; overflow: hidden; margin: 0 auto;
  }
  .story-hero-scroll-line::after {
    content: ''; position: absolute; top: -100%; left: 0;
    width: 100%; height: 100%; background: var(--gold-2);
    animation: scrollAnim 2s ease-in-out 1.5s infinite;
  }
  @keyframes scrollAnim { 0%{top:-100%;} 100%{top:100%;} }

  /* ─────────────────────────────────────
     INTRO QUOTE — Sets the tone
     ───────────────────────────────────── */
  .story-intro {
    padding: 140px 56px;
    text-align: center; max-width: 980px;
    margin: 0 auto;
  }
  .story-intro-label {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--teal); margin-bottom: 32px;
  }
  .story-intro-quote {
    font-family: var(--serif);
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 300; font-style: italic;
    line-height: 1.45; color: var(--ink);
    margin-bottom: 36px;
  }
  .story-intro-quote::before, .story-intro-quote::after {
    content: '“'; color: var(--gold);
    font-size: 3rem; line-height: 0; vertical-align: -.1em;
  }
  .story-intro-quote::after { content: '”'; }
  .story-intro-author {
    font-family: var(--sans); font-size: .68rem;
    letter-spacing: .3em; text-transform: uppercase;
    color: var(--gold);
    display: inline-flex; align-items: center; gap: 14px;
  }
  .story-intro-author::before, .story-intro-author::after {
    content: ''; width: 30px; height: 1px; background: var(--gold);
  }

  /* ─────────────────────────────────────
     NARRATIVE — The story in prose
     ───────────────────────────────────── */
  .story-narrative {
    max-width: 760px; margin: 0 auto;
    padding: 0 24px 140px;
  }
  .narrative-eyebrow {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--teal); margin-bottom: 24px;
    display: flex; align-items: center; gap: 14px;
  }
  .narrative-eyebrow::before { content:''; width:30px; height:1px; background:var(--teal); }
  .narrative-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 300; line-height: 1.15;
    color: var(--ink); margin-bottom: 40px;
  }
  .narrative-title em { font-style: italic; color: var(--teal); }
  .narrative-body p {
    font-family: var(--sans); font-size: 1rem; font-weight: 300;
    line-height: 2; color: var(--ink-soft);
    margin-bottom: 24px;
  }
  .narrative-body p:first-of-type::first-letter {
    font-family: var(--serif); font-size: 4rem;
    font-weight: 400; float: left;
    line-height: .85; padding: 8px 12px 0 0;
    color: var(--teal);
  }

  /* ─────────────────────────────────────
     FILM SECTION — Embedded video
     ───────────────────────────────────── */
  .story-film {
    background: var(--ink);
    padding: 100px 56px;
    text-align: center;
  }
  .film-eyebrow {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 24px;
  }
  .film-title {
    font-family: var(--serif);
    font-size: clamp(2.2rem, 4vw, 3.4rem);
    font-weight: 300; line-height: 1.15;
    color: var(--ivory); margin-bottom: 56px;
  }
  .film-title em { font-style: italic; color: var(--gold-2); }
  .film-frame {
    max-width: 1200px; margin: 0 auto;
    aspect-ratio: 16/9;
    background: #0a0907;
    border: 1px solid rgba(184,150,90,.2);
    position: relative; overflow: hidden;
  }
  .film-frame iframe {
    width: 100%; height: 100%; border: 0;
  }
  .film-frame.placeholder {
    display: flex; align-items: center; justify-content: center;
    color: var(--mist); font-family: var(--serif); font-style: italic;
  }

  /* ─────────────────────────────────────
     GALLERY — Editorial mixed layout
     ───────────────────────────────────── */
  .story-gallery {
    padding: 140px 0 60px;
  }
  .gallery-eyebrow-wrap {
    text-align: center; margin-bottom: 80px;
    padding: 0 56px;
  }
  .gallery-eyebrow {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--teal); margin-bottom: 24px;
  }
  .gallery-title {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 4vw, 4rem);
    font-weight: 300; line-height: 1.1; color: var(--ink);
  }
  .gallery-title em { font-style: italic; color: var(--teal); }

  /* Gallery image base */
  .gal-img {
    background-size: cover; background-position: center;
    background-color: #cdc1a8;
    position: relative; overflow: hidden;
  }
  .gal-img::after {
    content: ''; position: absolute; inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.12'/%3E%3C/svg%3E");
    mix-blend-mode: multiply;
    opacity: var(--show-noise, 1);
  }
  .gal-img.has-image::after { opacity: 0; }
  .gal-img.placeholder {
    background: linear-gradient(160deg, #d8cfb8 0%, #b8a98a 100%);
  }

  /* Gallery layout patterns */
  .gallery-row { display: grid; gap: 4px; padding: 0 4px 4px; }
  .gallery-row.full { grid-template-columns: 1fr; }
  .gallery-row.two { grid-template-columns: 1fr 1fr; }
  .gallery-row.three { grid-template-columns: 1fr 1fr 1fr; }
  .gallery-row.asym-l { grid-template-columns: 2fr 1fr; }
  .gallery-row.asym-r { grid-template-columns: 1fr 2fr; }

  .gal-img.tall { aspect-ratio: 3/4; }
  .gal-img.wide { aspect-ratio: 16/9; }
  .gal-img.square { aspect-ratio: 1/1; }
  .gal-img.cinema { aspect-ratio: 21/9; }

  /* Cinematic pull quote between galleries */
  .gallery-quote {
    text-align: center; padding: 100px 56px;
    max-width: 880px; margin: 0 auto;
  }
  .gallery-quote-text {
    font-family: var(--serif);
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    font-weight: 300; font-style: italic;
    line-height: 1.5; color: var(--ink);
    border-top: 1px solid var(--line);
    border-bottom: 1px solid var(--line);
    padding: 60px 0;
  }
  .gallery-quote-text em { color: var(--teal); }

  /* ─────────────────────────────────────
     STATS BAR — Numerical context
     ───────────────────────────────────── */
  .story-stats {
    background: var(--ivory-2);
    padding: 80px 56px;
    border-top: 1px solid var(--line-2);
    border-bottom: 1px solid var(--line-2);
  }
  .stats-grid {
    display: grid; grid-template-columns: repeat(4, 1fr);
    max-width: 1100px; margin: 0 auto;
    gap: 40px;
  }
  .stat-box { text-align: center; padding: 0 20px; }
  .stat-box strong {
    display: block;
    font-family: var(--serif); font-size: clamp(2.4rem, 4vw, 3.6rem);
    font-weight: 300; color: var(--teal); line-height: 1;
    margin-bottom: 12px;
  }
  .stat-box span {
    font-family: var(--sans); font-size: .62rem;
    letter-spacing: .25em; text-transform: uppercase;
    color: var(--mist);
  }

  /* ─────────────────────────────────────
     VENDOR CREDITS — SEO + relationships
     ───────────────────────────────────── */
  .vendors {
    padding: 120px 56px;
    max-width: 1100px; margin: 0 auto;
  }
  .vendors-header {
    text-align: center; margin-bottom: 64px;
  }
  .vendors-eyebrow {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--teal); margin-bottom: 20px;
  }
  .vendors-title {
    font-family: var(--serif);
    font-size: clamp(2rem, 3.5vw, 3rem);
    font-weight: 300; color: var(--ink);
  }
  .vendors-title em { font-style: italic; color: var(--teal); }
  .vendors-grid {
    display: grid; grid-template-columns: repeat(3, 1fr);
    gap: 1px; background: var(--line);
  }
  .vendor-item {
    background: var(--ivory);
    padding: 24px 28px;
    transition: background .3s;
  }
  .vendor-item:hover { background: var(--ivory-2); }
  .vendor-role {
    font-family: var(--sans); font-size: .58rem;
    letter-spacing: .28em; text-transform: uppercase;
    color: var(--gold); margin-bottom: 6px;
  }
  .vendor-name {
    font-family: var(--serif); font-size: 1.1rem;
    color: var(--ink);
  }
  .vendor-name a { color: var(--ink); text-decoration: none; transition: color .3s; }
  .vendor-name a:hover { color: var(--teal); }

  /* ─────────────────────────────────────
     STORY NAV — Previous/Next stories
     ───────────────────────────────────── */
  .story-nav {
    background: var(--ivory-2);
    border-top: 1px solid var(--line-2);
    display: grid; grid-template-columns: 1fr 1fr;
  }
  .story-nav-card {
    padding: 80px 56px;
    display: flex; flex-direction: column; gap: 16px;
    text-decoration: none; color: var(--ink);
    transition: background .35s;
    position: relative;
  }
  .story-nav-card:first-child {
    border-right: 1px solid var(--line);
  }
  .story-nav-card:hover { background: var(--ivory); }
  .story-nav-direction {
    font-family: var(--sans); font-size: .6rem;
    letter-spacing: .3em; text-transform: uppercase;
    color: var(--gold);
    display: flex; align-items: center; gap: 12px;
  }
  .story-nav-card.next .story-nav-direction { justify-content: flex-end; }
  .story-nav-couple {
    font-family: var(--serif); font-size: 2rem;
    font-weight: 300; color: var(--ink);
    transition: color .3s;
  }
  .story-nav-card:hover .story-nav-couple { color: var(--teal); }
  .story-nav-card.next { text-align: right; }
  .story-nav-meta {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .22em; text-transform: uppercase;
    color: var(--mist);
  }

  /* ─────────────────────────────────────
     CTA — Book your wedding
     ───────────────────────────────────── */
  .story-cta {
    padding: 140px 56px;
    text-align: center;
    background: linear-gradient(160deg, var(--teal-deep) 0%, var(--teal) 100%);
    color: var(--ivory);
    position: relative; overflow: hidden;
  }
  .story-cta::before {
    content: ''; position: absolute; inset: 0;
    background: radial-gradient(ellipse at 50% 50%, rgba(184,150,90,.1) 0%, transparent 60%);
  }
  .story-cta-eyebrow {
    font-family: var(--sans); font-size: .65rem;
    letter-spacing: .35em; text-transform: uppercase;
    color: var(--gold-2); margin-bottom: 24px;
    position: relative; z-index: 1;
  }
  .story-cta-title {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 4.5vw, 4rem);
    font-weight: 300; line-height: 1.1;
    margin-bottom: 20px; position: relative; z-index: 1;
  }
  .story-cta-title em { font-style: italic; color: var(--gold-2); }
  .story-cta-sub {
    font-family: var(--sans); font-size: .9rem;
    color: rgba(244,237,224,.7); margin-bottom: 40px;
    position: relative; z-index: 1;
  }
  .btn-gold {
    font-family: var(--sans); font-size: .72rem;
    letter-spacing: .25em; text-transform: uppercase;
    background: var(--gold); color: var(--teal-deep);
    padding: 16px 44px; text-decoration: none;
    transition: all .35s; display: inline-block;
    border: 1px solid var(--gold);
    position: relative; z-index: 1;
  }
  .btn-gold:hover { background: var(--gold-2); }

  /* FOOTER */
  footer { background: var(--ink); color: var(--ivory); padding: 60px 56px 36px; }
  .footer-inner { display: flex; justify-content: space-between; align-items: center; margin-bottom: 40px; flex-wrap: wrap; gap: 24px; }
  .footer-logo { display: flex; align-items: center; gap: 12px; text-decoration: none; color: inherit; }
  .footer-logo svg { width: 30px; height: 24px; color: var(--ivory); }
  .footer-brand-text { font-family: var(--serif); font-size: 1.2rem; font-weight: 500; line-height: 1; }
  .footer-brand-text small { display: block; font-family: var(--sans); font-size: .55rem; letter-spacing: .32em; color: var(--mist); margin-top: 5px; }
  .footer-links-row { display: flex; gap: 32px; flex-wrap: wrap; }
  .footer-links-row a { font-family: var(--sans); font-size: .68rem; letter-spacing: .18em; text-transform: uppercase; color: rgba(244,237,224,.45); text-decoration: none; transition: color .3s; }
  .footer-links-row a:hover { color: var(--gold); }
  .footer-bottom { border-top: 1px solid rgba(244,237,224,.08); padding-top: 24px; display: flex; justify-content: space-between; flex-wrap: wrap; gap: 14px; }
  .footer-copy { font-family: var(--sans); font-size: .65rem; color: rgba(244,237,224,.3); }

  /* WHATSAPP */
  .whatsapp-float {
    position: fixed; bottom: 32px; right: 32px; z-index: 200;
    width: 58px; height: 58px; border-radius: 50%;
    background: #25d366;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 8px 28px rgba(37,211,102,.35);
    text-decoration: none;
    animation: pulse 2.5s ease-in-out infinite;
  }
  .whatsapp-float svg { width: 30px; height: 30px; color: #fff; }
  @keyframes pulse {
    0%,100% { box-shadow: 0 8px 28px rgba(37,211,102,.35); }
    50% { box-shadow: 0 8px 28px rgba(37,211,102,.6), 0 0 0 14px rgba(37,211,102,.05); }
  }

  /* FOCUS */
  a:focus-visible, button:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 4px;
  }

  /* ANIMATIONS */
  @keyframes fadeUp { from { opacity:0; transform:translateY(28px); } to { opacity:1; transform:translateY(0); } }
  @keyframes fadeIn { from { opacity:0; } to { opacity:1; } }

  .reveal { opacity:0; transform:translateY(36px); transition: opacity .9s cubic-bezier(.22,1,.36,1), transform .9s cubic-bezier(.22,1,.36,1); }
  .reveal.visible { opacity:1; transform:translateY(0); }
  .reveal-d1 { transition-delay:.15s; }
  .reveal-d2 { transition-delay:.3s; }

  /* RESPONSIVE */
  @media (max-width: 980px) {
    body { cursor: auto; }
    .cursor { display: none; }
    nav { padding: 16px 20px; }
    nav.scrolled { padding: 12px 20px; }
    .nav-links { display: none; }
    .story-hero-content { padding: 0 24px 60px; }
    .story-hero-scroll { display: none; }
    .story-intro, .story-narrative, .story-film, .story-cta { padding-left: 24px; padding-right: 24px; }
    .gallery-eyebrow-wrap { padding: 0 24px; }
    .gallery-row.three { grid-template-columns: 1fr 1fr; }
    .gallery-row.asym-l, .gallery-row.asym-r { grid-template-columns: 1fr; }
    .stats-grid { grid-template-columns: 1fr 1fr; gap: 28px; }
    .vendors { padding: 80px 24px; }
    .vendors-grid { grid-template-columns: 1fr; }
    .story-nav { grid-template-columns: 1fr; }
    .story-nav-card { padding: 50px 24px; }
    .story-nav-card:first-child { border-right: none; border-bottom: 1px solid var(--line); }
    .story-nav-card.next { text-align: left; }
    .story-nav-card.next .story-nav-direction { justify-content: flex-start; }
    footer { padding: 40px 24px 28px; }
  }
  @media (max-width: 600px) {
    .gallery-row.three { grid-template-columns: 1fr; }
    .gallery-row.two { grid-template-columns: 1fr; }
    .story-hero-meta { gap: 20px; }
    .story-hero-meta-item::before { display: none; }
  }
</style>
</head>
<body>

<!-- Custom cursor -->
<div class="cursor" id="cursor">
  <div class="cursor-dot" id="cursorDot"></div>
  <div class="cursor-ring" id="cursorRing"></div>
</div>

<!-- ────── NAV ────── -->
<nav id="nav">
  <a href="/" class="nav-logo">
    <div class="nav-mark">
      <svg viewBox="0 0 80 60" fill="currentColor" role="img" aria-label="Memorygraph">
        <path d="M 5 55 L 5 5 L 30 55 Z"/>
        <path d="M 28 5 L 52 5 L 40 32 Z"/>
        <path d="M 75 55 L 75 5 L 50 55 Z"/>
      </svg>
    </div>
    <div class="nav-wordmark">Memorygraph<small>Photographing Memories</small></div>
  </a>
  <ul class="nav-links">
    <li><a href="/stories/" class="active">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/investment/">Investment</a></li>
    <li><a href="/blog/">Journal</a></li>
  </ul>
  <a href="/contact/" class="nav-cta">Begin Your Story</a>
</nav>

<!-- ────── STORY HERO ────── -->
<section class="story-hero">
  <!-- Replace url('') below with the hero image path. Remove "placeholder" class after. -->
  <div class="story-hero-img placeholder" style="background-image: url('{{ hero }}');"></div>
  <div class="story-hero-overlay"></div>
  <div class="story-hero-content">
    <div class="story-hero-eyebrow">A Wedding Story</div>
    <h1 class="story-hero-name">{{ title }}</h1>
    <div class="story-hero-meta">
      <div class="story-hero-meta-item">{{ location }}</div>
      <div class="story-hero-meta-item">{{ date | formatDate }}</div>
      <div class="story-hero-meta-item">By Memorygraph</div>
    </div>
  </div>
  <div class="story-hero-scroll">
    <div class="story-hero-scroll-line"></div>
  </div>
</section>

<!-- ────── INTRO QUOTE ────── -->
<section class="story-intro">
  <div class="story-intro-label">In Their Own Words</div>
  <blockquote class="story-intro-quote">{{ quote }}</blockquote>
  <div class="story-intro-author">{{ quote_by if quote_by else title }}</div>
</section>

<!-- ────── NARRATIVE ────── -->
<article class="story-narrative">
  <div class="narrative-eyebrow">The Story</div>
  <h2 class="narrative-title">{{ chapter_title | safe if chapter_title else title }}</h2>
  <div class="narrative-body">
    {{ content | safe }}
  </div>
</article>

<!-- ────── FILM ────── -->
{% if film_url %}
<section class="story-film">
  <div class="film-eyebrow">Watch the Film</div>
  <h2 class="film-title">A short film of <em>their day</em>.</h2>
  {% if film_url %}
  <div class="film-frame">
    <iframe src="{{ film_url }}"
            title="Wedding film of {{ title }}"
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
            allowfullscreen></iframe>
  </div>
  {% else %}
  <div class="film-frame placeholder" style="padding:80px;font-family:var(--serif);font-style:italic;color:var(--mist);">
    Film coming soon.
  </div>
  {% endif %}
</section>
{% endif %}

<!-- ────── GALLERY ────── -->
<section class="story-gallery">
  <div class="gallery-eyebrow-wrap">
    <div class="gallery-eyebrow">The Photographs</div>
    <h2 class="gallery-title">Frames from <em>the day</em>.</h2>
  </div>

  <!-- 
    GALLERY LAYOUT GUIDE:
    Mix and match these row types for editorial feel:
      .gallery-row.full        — single full-width image
      .gallery-row.two         — two equal images side-by-side
      .gallery-row.three       — three equal images
      .gallery-row.asym-l      — large left, small right (2:1)
      .gallery-row.asym-r      — small left, large right (1:2)
    
    Image aspect ratios:
      .gal-img.tall            — 3:4 (portrait)
      .gal-img.wide            — 16:9 (landscape)
      .gal-img.cinema          — 21:9 (widescreen)
      .gal-img.square          — 1:1
    
    Replace inline style url('') with real image paths.
    Add class "has-image" to images that have real photos (removes the noise placeholder).
  -->

   {% for row in gallery %}

    {% if row.layout == "full" %}
      <div class="gallery-row full">
        <div class="gal-img cinema" style="background-image:url('{{ row.images[0] }}')"></div>
      </div>
    {% endif %}

    {% if row.layout == "two" %}
      <div class="gallery-row two">
        <div class="gal-img tall" style="background-image:url('{{ row.images[0] }}')"></div>
        <div class="gal-img tall" style="background-image:url('{{ row.images[1] }}')"></div>
      </div>
    {% endif %}

    {% if row.layout == "three" %}
      <div class="gallery-row three">
        <div class="gal-img square" style="background-image:url('{{ row.images[0] }}')"></div>
        <div class="gal-img square" style="background-image:url('{{ row.images[1] }}')"></div>
        <div class="gal-img square" style="background-image:url('{{ row.images[2] }}')"></div>
      </div>
    {% endif %}

    {% if row.layout == "asym-l" %}
      <div class="gallery-row asym-l">
        <div class="gal-img wide" style="background-image:url('{{ row.images[0] }}')"></div>
        <div class="gal-img tall" style="background-image:url('{{ row.images[1] }}')"></div>
      </div>
    {% endif %}

    {% if row.layout == "asym-r" %}
      <div class="gallery-row asym-r">
        <div class="gal-img tall" style="background-image:url('{{ row.images[0] }}')"></div>
        <div class="gal-img wide" style="background-image:url('{{ row.images[1] }}')"></div>
      </div>
    {% endif %}

    {% if row.layout == "quote" %}
      <div class="gallery-quote">
        <blockquote class="gallery-quote-text">
          {{ row.text }}
        </blockquote>
      </div>
    {% endif %}

  {% endfor %}
</section>

<!-- ────── STATS ────── -->
<section class="story-stats">
  <div class="stats-grid">
    <div class="stat-box"><strong>{{ stat_images if stat_images else "—" }}</strong><span>Images Delivered</span></div>
    <div class="stat-box"><strong>{{ stat_hours if stat_hours else "—" }}</strong><span>Hours of Coverage</span></div>
    <div class="stat-box"><strong>{{ stat_photographers if stat_photographers else "2" }}</strong><span>Photographers</span></div>
    <div class="stat-box"><strong>{{ date | formatDate }}</strong><span>Wedding Day</span></div>
  </div>
</section>

<!-- ────── VENDOR CREDITS ────── -->
<section class="vendors">
  <div class="vendors-header">
    <div class="vendors-eyebrow">In Good Company</div>
    <h2 class="vendors-title">The team behind <em>this day</em>.</h2>
  </div>
  <div class="vendors-grid">
    <!-- 
      EDIT: Replace vendor names. Link them to their websites/Instagram if they have one.
      Remove any rows you don't need. Add more by copying any item.
    -->
    <div class="vendor-item">
      <div class="vendor-role">Venue</div>
      <div class="vendor-name">{{ location }}</div>
    </div>
    <div class="vendor-item">
      <div class="vendor-role">Bridal Makeup</div>
      <div class="vendor-name"><a href="#">Sruthi MUA</a></div>
    </div>
    <div class="vendor-item">
      <div class="vendor-role">Florals</div>
      <div class="vendor-name">Florals by Anjali</div>
    </div>
    <div class="vendor-item">
      <div class="vendor-role">Wedding Planner</div>
      <div class="vendor-name">Self-planned</div>
    </div>
    <div class="vendor-item">
      <div class="vendor-role">Catering</div>
      <div class="vendor-name">Pavithram Caterers</div>
    </div>
    <div class="vendor-item">
      <div class="vendor-role">Photo &amp; Film</div>
      <div class="vendor-name"><a href="/">Memorygraph Wedding Studio</a></div>
    </div>
  </div>
</section>


<!-- ────── PREV / NEXT STORY ────── -->
{%- set prevStory = collections.stories | getPreviousCollectionItem -%}
{%- set nextStory = collections.stories | getNextCollectionItem -%}
<nav class="story-nav">
  {% if prevStory %}
  <a href="{{ prevStory.url }}" class="story-nav-card prev">
    <div class="story-nav-direction">
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M5 1L1 5l4 4M13 5H1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      Previous Story
    </div>
    <div class="story-nav-couple">{{ prevStory.data.title }}</div>
    <div class="story-nav-meta">{{ prevStory.data.location_short }} · {{ prevStory.date | formatDate }}</div>
  </a>
  {% else %}
  <a href="/stories/" class="story-nav-card prev">
    <div class="story-nav-direction">
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M5 1L1 5l4 4M13 5H1" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
      All Stories
    </div>
    <div class="story-nav-couple">View all stories</div>
    <div class="story-nav-meta">Memorygraph Wedding Studio</div>
  </a>
  {% endif %}
  {% if nextStory %}
  <a href="{{ nextStory.url }}" class="story-nav-card next">
    <div class="story-nav-direction">
      Next Story
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    </div>
    <div class="story-nav-couple">{{ nextStory.data.title }}</div>
    <div class="story-nav-meta">{{ nextStory.data.location_short }} · {{ nextStory.date | formatDate }}</div>
  </a>
  {% else %}
  <a href="/stories/" class="story-nav-card next">
    <div class="story-nav-direction">
      All Stories
      <svg width="14" height="10" viewBox="0 0 14 10" fill="none"><path d="M9 1l4 4-4 4M1 5h12" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    </div>
    <div class="story-nav-couple">View all stories</div>
    <div class="story-nav-meta">Memorygraph Wedding Studio</div>
  </a>
  {% endif %}
</nav>

<!-- ────── CTA ────── -->
<section class="story-cta">
  <div class="story-cta-eyebrow">Could yours be next?</div>
  <h2 class="story-cta-title">Let's tell <em>your</em><br>story, beautifully.</h2>
  <p class="story-cta-sub">A few openings remaining for the season. Kerala &amp; destination weddings welcome.</p>
  <a href="/contact/" class="btn-gold">Begin Your Story</a>
</section>

<!-- ────── FOOTER ────── -->
<footer>
  <div class="footer-inner">
    <a href="/" class="footer-logo">
      <img src="/assets/logo/logo.jpg" alt="Memorygraph Wedding Studio" style="height:52px;width:auto;mix-blend-mode:screen;opacity:.9;"/>
    </a>
    <div class="footer-links-row">
      <a href="/">Home</a>
      <a href="/stories/">Stories</a>
      <a href="/about/">About</a>
      <a href="/investment/">Investment</a>
      <a href="/blog/">Journal</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">© 2026 Memorygraph Wedding Studio · Thrissur, Kerala</div>
    <div class="footer-copy">+91 82816 39563 · hello@memorygraphweddings.com</div>
  </div>
</footer>

<!-- WhatsApp -->
<a href="https://wa.me/919846238073?text=Hi%20Arun%2C%20I%27d%20love%20to%20discuss%20my%20wedding." class="whatsapp-float" target="_blank" aria-label="Chat on WhatsApp">
  <svg viewBox="0 0 32 32" fill="currentColor">
    <path d="M16 .4C7.4.4.4 7.4.4 16c0 2.84.74 5.62 2.16 8.06L.27 31.6l7.74-2.27C10.36 30.7 13.14 31.5 16 31.5c8.6 0 15.6-7 15.6-15.5C31.6 7.4 24.6.4 16 .4zM16 28.7c-2.5 0-4.96-.66-7.1-1.92l-.5-.3-5.34 1.55 1.6-5.18-.34-.55C2.92 19.92 2.2 18 2.2 16 2.2 8.4 8.4 2.2 16 2.2c7.6 0 13.8 6.2 13.8 13.8 0 7.6-6.2 12.7-13.8 12.7zm7.6-9.8c-.4-.2-2.4-1.18-2.78-1.32-.38-.14-.66-.2-.94.2-.28.4-1.06 1.32-1.3 1.6-.24.28-.48.3-.88.1-.4-.2-1.7-.62-3.24-2-1.2-1.06-2-2.38-2.24-2.78-.24-.4-.02-.62.18-.82.18-.18.4-.46.6-.7.2-.24.26-.4.4-.68.14-.28.06-.52-.04-.72-.1-.2-.92-2.22-1.26-3.04-.34-.8-.68-.7-.94-.72h-.8c-.28 0-.72.1-1.1.5-.38.4-1.44 1.4-1.44 3.42s1.48 3.96 1.68 4.24c.2.28 2.92 4.46 7.08 6.24 1 .42 1.78.68 2.38.88.98.32 1.88.28 2.6.16.78-.12 2.4-.98 2.74-1.92.34-.94.34-1.74.24-1.92-.1-.18-.36-.28-.76-.48z"/>
  </svg>
</a>

<script>
  // Cursor
  const dot = document.getElementById('cursorDot'), ring = document.getElementById('cursorRing');
  let mx = 0, my = 0, rx = 0, ry = 0;
  document.addEventListener('mousemove', e => { mx = e.clientX; my = e.clientY; });
  function ac() {
    dot.style.left = mx + 'px'; dot.style.top = my + 'px';
    rx += (mx - rx) * .13; ry += (my - ry) * .13;
    ring.style.left = rx + 'px'; ring.style.top = ry + 'px';
    requestAnimationFrame(ac);
  } ac();
  document.querySelectorAll('a, button').forEach(el => {
    el.addEventListener('mouseenter', () => { ring.style.width = '40px'; ring.style.height = '40px'; });
    el.addEventListener('mouseleave', () => { ring.style.width = '24px'; ring.style.height = '24px'; });
  });

  // Nav scroll
  window.addEventListener('scroll', () => document.getElementById('nav').classList.toggle('scrolled', scrollY > 60));

  // Reveal on scroll
  const obs = new IntersectionObserver(e => e.forEach(x => {
    if (x.isIntersecting) { x.target.classList.add('visible'); obs.unobserve(x.target); }
  }), { threshold: .1 });
  document.querySelectorAll('.reveal').forEach(r => obs.observe(r));

  // Lazy load gallery images (basic native lazy loading via background-image trick)
  // For best performance, replace background-image divs with <img loading="lazy">
</script>

</body>
</html>
