---
permalink: /blog/index.html
eleventyExcludeFromCollections: true
---
{% set featuredPosts = collections.blog | selectattr("data.featured") | list %}
{% set featuredPost = featuredPosts[0] if featuredPosts and featuredPosts.length else collections.blog[0] %}
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Wedding Journal, Guides and Kerala Wedding Ideas | Memorygraph</title>
<meta name="description" content="Planning guides, real Kerala wedding stories, photography advice, and behind-the-scenes notes from Memorygraph Wedding Studio in Thrissur."/>
<meta name="keywords" content="Kerala wedding blog, wedding planning guide Kerala, Thrissur wedding photographer blog, Memorygraph journal, Kerala wedding ideas"/>
<meta name="author" content="Arun T Chandran"/>
<meta name="robots" content="index, follow"/>
<meta property="og:title" content="Wedding Journal, Guides and Kerala Wedding Ideas | Memorygraph"/>
<meta property="og:description" content="Planning guides, real Kerala wedding stories, photography advice, and behind-the-scenes notes from Memorygraph Wedding Studio."/>
<meta property="og:type" content="website"/>
<meta property="og:url" content="{{ '/blog/' | absoluteUrl(site.url) }}"/>
<meta property="og:image" content="{{ (featuredPost.data.hero or site.defaultSocialImage) | absoluteUrl(site.url) }}"/>
<meta property="og:locale" content="{{ site.locale }}"/>
<meta property="og:site_name" content="{{ site.shortName }}"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="Wedding Journal, Guides and Kerala Wedding Ideas | Memorygraph"/>
<meta name="twitter:description" content="Planning guides, real Kerala wedding stories, photography advice, and behind-the-scenes notes from Memorygraph Wedding Studio."/>
<meta name="twitter:image" content="{{ (featuredPost.data.hero or site.defaultSocialImage) | absoluteUrl(site.url) }}"/>
<link rel="canonical" href="{{ '/blog/' | absoluteUrl(site.url) }}"/>
<link rel="icon" href="/assets/logo/logo-dark.png" type="image/png"/>
<link rel="apple-touch-icon" href="/assets/logo/logo-dark.png"/>
<link rel="alternate" type="application/rss+xml" title="Memorygraph Journal RSS" href="{{ '/feed.xml' | absoluteUrl(site.url) }}"/>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Blog",
  "name": "Memorygraph Journal",
  "headline": "Memorygraph Journal",
  "description": "Planning guides, real Kerala wedding stories, photography advice, and behind-the-scenes notes from Memorygraph Wedding Studio.",
  "url": "{{ '/blog/' | absoluteUrl(site.url) }}",
  "publisher": {
    "@type": "Organization",
    "name": "{{ site.name }}",
    "logo": {
      "@type": "ImageObject",
      "url": "{{ '/assets/logo/logo-dark.png' | absoluteUrl(site.url) }}"
    }
  }
}
</script>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/assets/css/global.css"/>
<link rel="stylesheet" href="/assets/css/animations.css"/>
<style>
  .page-hero{padding:200px 56px 80px;text-align:center;position:relative;overflow:hidden;}
  .page-hero::before{content:'';position:absolute;top:0;right:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(184,150,90,.08) 0%,transparent 70%);}
  .page-hero::after{content:'';position:absolute;bottom:0;left:-100px;width:400px;height:400px;border-radius:50%;background:radial-gradient(circle,rgba(29,89,89,.06) 0%,transparent 70%);}
  .ph-label{font-family:var(--sans);font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--teal);margin-bottom:24px;position:relative;z-index:1;}
  .page-hero h1{font-family:var(--serif);font-size:clamp(3.5rem,7vw,7.5rem);font-weight:300;line-height:1;color:var(--ink);position:relative;z-index:1;}
  .page-hero h1 em{font-style:italic;color:var(--teal);}
  .ph-sub{font-family:var(--sans);font-size:.92rem;font-weight:300;color:var(--ink-soft);margin:32px auto 0;max-width:720px;line-height:1.9;position:relative;z-index:1;}
  .cat-bar{padding:32px 56px;text-align:center;border-top:1px solid var(--line-2);border-bottom:1px solid var(--line-2);background:var(--ivory-2);}
  .cat-bar-inner{display:inline-flex;gap:8px;flex-wrap:wrap;justify-content:center;}
  .cat-btn{font-family:var(--sans);font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;padding:10px 20px;border:1px solid var(--line);color:var(--ink-soft);background:transparent;cursor:pointer;transition:all .3s;}
  .cat-btn.active,.cat-btn:hover{border-color:var(--teal);color:var(--teal);background:var(--ivory);}
  .featured-article{padding:100px 56px;display:grid;grid-template-columns:1.2fr 1fr;gap:80px;align-items:center;}
  .feat-img{position:relative;}
  .feat-frame{width:100%;padding-bottom:75%;background:linear-gradient(160deg,#d8cfb8 0%,#a89a78 100%);position:relative;overflow:hidden;}
  .feat-frame img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;}
  .feat-frame::after{content:'';position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.16'/%3E%3C/svg%3E");mix-blend-mode:multiply;}
  .feat-badge{position:absolute;top:24px;left:-12px;background:var(--teal);color:var(--ivory);font-family:var(--sans);font-size:.58rem;letter-spacing:.25em;text-transform:uppercase;padding:8px 18px;}
  .feat-cat{font-family:var(--sans);font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:18px;}
  .feat-title{font-family:var(--serif);font-size:clamp(2rem,3.5vw,3.4rem);font-weight:300;line-height:1.15;color:var(--ink);margin-bottom:24px;}
  .feat-excerpt{font-family:var(--sans);font-size:.95rem;font-weight:300;line-height:1.85;color:var(--ink-soft);margin-bottom:32px;}
  .feat-meta-row{display:flex;align-items:center;gap:20px;margin-bottom:36px;font-family:var(--sans);font-size:.7rem;color:var(--mist);letter-spacing:.1em;flex-wrap:wrap;}
  .feat-meta-row .dot,.a-meta .dot{width:3px;height:3px;background:var(--mist);border-radius:50%;}
  .btn-read{font-family:var(--sans);font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;color:var(--teal);text-decoration:none;border-bottom:1px solid var(--teal);padding-bottom:6px;display:inline-flex;align-items:center;gap:10px;transition:gap .3s;}
  .btn-read:hover{gap:18px;}
  .articles-section{padding:80px 56px 140px;border-top:1px solid var(--line-2);}
  .grid-title{font-family:var(--serif);font-size:1.6rem;font-weight:300;color:var(--mist);margin-bottom:56px;font-style:italic;}
  .articles-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:48px 32px;}
  .article-card{background:transparent;display:block;text-decoration:none;color:inherit;}
  .a-img{width:100%;padding-bottom:65%;position:relative;overflow:hidden;margin-bottom:24px;background:linear-gradient(160deg,#d8cfb8 0%,#b8a98a 100%);}
  .a-img img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .8s cubic-bezier(.22,1,.36,1);}
  .article-card:hover .a-img img{transform:scale(1.05);}
  .a-noise{position:absolute;inset:0;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='.15'/%3E%3C/svg%3E");mix-blend-mode:multiply;}
  .a-cat{position:absolute;top:16px;left:16px;font-family:var(--sans);font-size:.55rem;letter-spacing:.22em;text-transform:uppercase;color:var(--ivory);background:rgba(26,24,20,.55);backdrop-filter:blur(8px);padding:6px 12px;}
  .a-title{font-family:var(--serif);font-size:1.5rem;font-weight:400;line-height:1.25;color:var(--ink);margin-bottom:12px;transition:color .3s;}
  .article-card:hover .a-title{color:var(--teal);}
  .a-excerpt{font-family:var(--sans);font-size:.85rem;font-weight:300;line-height:1.7;color:var(--ink-soft);margin-bottom:18px;}
  .a-meta{font-family:var(--sans);font-size:.62rem;letter-spacing:.18em;text-transform:uppercase;color:var(--mist);display:flex;align-items:center;gap:12px;flex-wrap:wrap;}
  .newsletter{padding:120px 56px;background:linear-gradient(160deg,var(--teal-deep) 0%,var(--teal) 100%);color:var(--ivory);text-align:center;position:relative;overflow:hidden;}
  .newsletter::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(184,150,90,.1) 0%,transparent 60%);}
  .nl-label{font-family:var(--sans);font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;position:relative;z-index:1;}
  .nl-title{font-family:var(--serif);font-size:clamp(2.4rem,4vw,4rem);font-weight:300;line-height:1.1;margin-bottom:20px;position:relative;z-index:1;}
  .nl-title em{font-style:italic;color:var(--gold-2);}
  .nl-sub{font-family:var(--sans);font-size:.9rem;color:rgba(244,237,224,.7);margin-bottom:40px;position:relative;z-index:1;max-width:540px;margin-left:auto;margin-right:auto;}
  .nl-actions{position:relative;z-index:1;display:flex;justify-content:center;gap:16px;flex-wrap:wrap;}
  .nl-btn{font-family:var(--sans);font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;padding:14px 28px;text-decoration:none;border:1px solid rgba(244,237,224,.25);color:var(--ivory);}
  .nl-btn.primary{background:var(--gold);border-color:var(--gold);color:var(--teal-deep);}
  @media (max-width:980px){
    .page-hero{padding:140px 24px 60px;}
    .cat-bar{padding:24px 20px;}
    .featured-article,.articles-section,.newsletter{padding:60px 20px;}
    .featured-article{grid-template-columns:1fr;gap:40px;}
    .articles-grid{grid-template-columns:1fr;gap:40px;}
  }
  @media (min-width:601px) and (max-width:980px){.articles-grid{grid-template-columns:1fr 1fr;}}
</style>
</head>
<body>
<div class="preloader" id="preloader"><div class="preloader-logo">Memorygraph<small>Photographing Memories</small></div><div class="preloader-line"></div></div>
<div class="page-transition-overlay"></div>
<nav id="nav">
  <a href="/" class="nav-logo"><img src="/assets/logo/logo-dark.png" alt="Memorygraph Wedding Studio" style="height:48px;width:auto;max-width:160px;display:block;"/></a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/stories/">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/investment/">Investment</a></li>
    <li><a href="/blog/" class="active">Journal</a></li>
  </ul>
  <a href="/contact/" class="nav-cta">Begin Your Story</a>
</nav>
<div class="page-hero">
  <div class="ph-label">The Journal</div>
  <h1>Notes for couples,<br><em>not just portfolios.</em></h1>
  <p class="ph-sub">A journal of Kerala wedding planning advice, honest photography guidance, and the kinds of small observations that help couples make calmer, better decisions before the day arrives.</p>
</div>
<div class="cat-bar">
  <div class="cat-bar-inner">
    <button class="cat-btn active" data-filter="all">All Posts</button>
    <button class="cat-btn" data-filter="Planning Guides">Planning Guides</button>
    <button class="cat-btn" data-filter="Wedding Stories">Wedding Stories</button>
    <button class="cat-btn" data-filter="Photography Advice">Photography Advice</button>
    <button class="cat-btn" data-filter="Kerala Weddings">Kerala Weddings</button>
  </div>
</div>
{% if featuredPost %}
<div class="featured-article">
  <div class="feat-img reveal">
    <div class="feat-badge">Featured Read</div>
    <div class="feat-frame"><img src="{{ featuredPost.data.hero or site.defaultSocialImage }}" alt="{{ featuredPost.data.imageAlt or featuredPost.data.title }}" loading="eager"/></div>
  </div>
  <div class="feat-content reveal reveal-d1">
    <div class="feat-cat">{{ featuredPost.data.category }} · {{ featuredPost.templateContent | readingTime }} min read</div>
    <h2 class="feat-title">{{ featuredPost.data.title }}</h2>
    <p class="feat-excerpt">{{ featuredPost.data.excerpt or featuredPost.data.description }}</p>
    <div class="feat-meta-row">
      <span>By {{ featuredPost.data.author or 'Arun T Chandran' }}</span>
      <div class="dot"></div>
      <span>{{ featuredPost.date | formatDate }}</span>
      <div class="dot"></div>
      <span>{{ featuredPost.templateContent | readingTime }} min read</span>
    </div>
    <a href="{{ featuredPost.url }}" class="btn-read">Read the article <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M10 1l5 4-5 4M1 5h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg></a>
  </div>
</div>
{% endif %}
<div class="articles-section">
  <div class="grid-title reveal">More from the journal</div>
  <div class="articles-grid" data-cms="blog-grid">
    {% for post in collections.blog %}
    <a href="{{ post.url }}" class="article-card reveal{% if loop.index == 2 %} reveal-d1{% elseif loop.index == 3 %} reveal-d2{% endif %}" data-category="{{ post.data.category }}">
      <div class="a-img">
        <img src="{{ post.data.hero or site.defaultSocialImage }}" alt="{{ post.data.imageAlt or post.data.title }}" loading="lazy"/>
        <div class="a-noise"></div>
        <div class="a-cat">{{ post.data.category }}</div>
      </div>
      <h3 class="a-title">{{ post.data.title }}</h3>
      <p class="a-excerpt">{{ post.data.excerpt or post.data.description }}</p>
      <div class="a-meta"><span>{{ post.date | formatDate }}</span><div class="dot"></div><span>{{ post.templateContent | readingTime }} min read</span></div>
    </a>
    {% endfor %}
  </div>
</div>
<div class="newsletter">
  <div class="nl-label">Read, Then Reach Out</div>
  <h2 class="nl-title">Need advice that fits<br><em>your actual wedding?</em></h2>
  <p class="nl-sub">The journal covers the common questions. For the personal ones, we are always happy to talk through light, timelines, coverage, and what would actually make sense for your day.</p>
  <div class="nl-actions">
    <a href="/contact/" class="nl-btn primary">Start the Conversation</a>
    <a href="/feed.xml" class="nl-btn">Follow via RSS</a>
  </div>
</div>
<footer>
  <div class="footer-inner">
    <a href="/" class="footer-logo"><img src="/assets/logo/logo-white.png" alt="Memorygraph Wedding Studio" style="height:52px;width:auto;mix-blend-mode:screen;opacity:.9;"/></a>
    <div class="footer-links-row">
      <a href="/">Home</a><a href="/stories/">Stories</a><a href="/about/">About</a><a href="/investment/">Investment</a><a href="/blog/">Journal</a><a href="/contact/">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">© 2026 Memorygraph Wedding Studio · Thrissur, Kerala</div>
    <div class="footer-socials"><a href="{{ site.socials.instagram }}" target="_blank" rel="noopener">Instagram</a><a href="{{ site.socials.youtube }}" target="_blank" rel="noopener">YouTube</a><a href="{{ site.socials.facebook }}" target="_blank" rel="noopener">Facebook</a></div>
  </div>
</footer>
<!-- MOBILE STICKY CTA -->
<div class="mobile-cta-bar" id="mobileCta">
  <div class="mobile-cta-bar-inner">
    <span class="mobile-cta-bar-text">Season dates filling up</span>
    <a href="/contact/">Begin Your Story</a>
  </div>
</div>

