<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="author" content="Memorygraph Wedding Studio"/>
<meta name="robots" content="index, follow"/>
<meta name="description" content="A curated portfolio of cinematic Kerala wedding stories — temple weddings, heritage venues, destinations. Photographed and filmed by Memorygraph Wedding Studio."/>
<meta name="keywords" content="Kerala Wedding Stories, Temple Wedding Photography, Heritage Venue Wedding, Destination Wedding Kerala, Memorygraph Portfolio"/>
<title>Wedding Stories | Real Kerala Weddings | Memorygraph</title>
<meta property="og:title" content="Wedding Stories | Real Kerala Weddings | Memorygraph"/>
<meta property="og:description" content="A curated portfolio of cinematic Kerala wedding stories — temple weddings, heritage venues, destinations."/>
<meta property="og:type" content="website"/>
<meta property="og:url" content="https://memorygraphweddings.com/stories/"/>
<meta property="og:image" content="https://memorygraphweddings.com/assets/og-stories.jpg"/>
<meta property="og:locale" content="en_IN"/>
<meta property="og:site_name" content="Memorygraph Weddings"/>
<meta name="twitter:card" content="summary_large_image"/>
<meta name="twitter:title" content="Wedding Stories | Real Kerala Weddings | Memorygraph"/>
<meta name="twitter:description" content="A curated portfolio of cinematic Kerala wedding stories — temple weddings, heritage venues, destinations."/>
<meta name="twitter:image" content="https://memorygraphweddings.com/assets/og-stories.jpg"/>
<link rel="canonical" href="https://memorygraphweddings.com/stories/"/>
<link rel="icon" href="/assets/logo/logo-dark.png" type="image/png"/>
<link rel="apple-touch-icon" href="/assets/logo/logo-dark.png"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="/assets/css/global.css"/>
<link rel="stylesheet" href="/assets/css/animations.css"/>

<style>
  /* PAGE HERO */
  .page-hero{padding:200px 56px 100px;position:relative;overflow:hidden;text-align:center;}
  .ph-label{font-family:var(--sans);font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--teal);margin-bottom:24px;display:flex;align-items:center;justify-content:center;gap:14px;}
  .ph-label::before,.ph-label::after{content:'';width:32px;height:1px;background:var(--teal);}
  .page-hero h1{font-family:var(--serif);font-size:clamp(3.6rem,7vw,8rem);font-weight:300;line-height:1;color:var(--ink);position:relative;}
  .page-hero h1 em{font-style:italic;color:var(--teal);}
  .ph-sub{font-family:var(--sans);font-size:.92rem;font-weight:300;color:var(--ink-soft);margin:32px auto 0;max-width:560px;line-height:1.9;}

  /* STORY ROW */
  .story-row{display:grid;grid-template-columns:1.15fr .85fr;gap:80px;align-items:center;padding:100px 56px;border-top:1px solid var(--line-2);}
  .story-row:nth-child(even){direction:rtl;}
  .story-row:nth-child(even) > *{direction:ltr;}
  .story-row-img{position:relative;overflow:hidden;aspect-ratio:3/4;}
  .story-row-img-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .8s cubic-bezier(.22,1,.36,1);}
  .story-row-img:hover .story-row-img-bg{transform:scale(1.03);}
  .story-row-corner-tl{position:absolute;top:-14px;left:-14px;width:80px;height:80px;border-top:1px solid var(--teal);border-left:1px solid var(--teal);z-index:2;}
  .story-row-corner-br{position:absolute;bottom:-14px;right:-14px;width:80px;height:80px;border-bottom:1px solid var(--gold);border-right:1px solid var(--gold);z-index:2;}
  .story-row-body{}
  .story-row-label{font-family:var(--sans);font-size:.6rem;letter-spacing:.3em;text-transform:uppercase;color:var(--gold);margin-bottom:18px;}
  .story-row-name{font-family:var(--serif);font-size:clamp(2.4rem,4vw,4.2rem);font-weight:300;font-style:italic;line-height:1.1;color:var(--ink);margin-bottom:12px;}
  .story-row-loc{font-family:var(--sans);font-size:.65rem;letter-spacing:.25em;text-transform:uppercase;color:var(--teal);margin-bottom:36px;display:flex;align-items:center;gap:10px;}
  .story-row-loc::before{content:'';width:20px;height:1px;background:var(--teal);}
  .story-row-quote{font-family:var(--serif);font-size:1.2rem;font-style:italic;line-height:1.75;color:var(--ink-soft);margin-bottom:36px;border-left:2px solid var(--gold);padding-left:24px;}
  .story-row-stats{display:flex;gap:40px;margin-bottom:40px;}
  .story-row-stat strong{display:block;font-family:var(--serif);font-size:2rem;font-weight:300;color:var(--teal);}
  .story-row-stat span{font-family:var(--sans);font-size:.58rem;letter-spacing:.22em;text-transform:uppercase;color:var(--mist);}
  .btn-story{font-family:var(--sans);font-size:.7rem;letter-spacing:.22em;text-transform:uppercase;color:var(--teal);text-decoration:none;border:1px solid var(--teal);padding:14px 32px;display:inline-flex;align-items:center;gap:12px;transition:all .35s;}
  .btn-story:hover{background:var(--teal);color:var(--ivory);}

  /* CTA STRIP */
  .cta-strip{padding:120px 56px;text-align:center;background:linear-gradient(160deg,var(--teal-deep) 0%,var(--teal) 100%);color:var(--ivory);position:relative;overflow:hidden;}
  .cta-strip::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(184,150,90,.1) 0%,transparent 60%);}
  .cs-label{font-family:var(--sans);font-size:.65rem;letter-spacing:.35em;text-transform:uppercase;color:var(--gold);margin-bottom:24px;}
  .cs-title{font-family:var(--serif);font-size:clamp(2.4rem,4vw,4rem);font-weight:300;line-height:1.1;margin-bottom:20px;position:relative;z-index:1;}
  .cs-title em{font-style:italic;color:var(--gold-2);}
  .cs-sub{font-family:var(--sans);font-size:.9rem;font-weight:300;color:rgba(244,237,224,.7);margin-bottom:40px;position:relative;z-index:1;}
  .btn-gold{font-family:var(--sans);font-size:.7rem;letter-spacing:.25em;text-transform:uppercase;background:var(--gold);color:var(--teal-deep);padding:16px 40px;text-decoration:none;transition:all .35s;display:inline-block;border:1px solid var(--gold);position:relative;z-index:1;}
  .btn-gold:hover{background:var(--gold-2);}

  @media (max-width:980px){
    .page-hero{padding:140px 24px 60px;}
    .story-row{padding:60px 24px;grid-template-columns:1fr;gap:40px;}
    .story-row:nth-child(even){direction:ltr;}
    .story-row-img{aspect-ratio:4/3;}
    .cta-strip{padding:80px 24px;}
  }
  @media (max-width:600px){
    .story-row-stats{gap:24px;}
  }
</style>
</head>
<body>

<!-- PRELOADER -->
<div class="preloader" id="preloader">
  <div class="preloader-logo">Memorygraph<small>Photographing Memories</small></div>
  <div class="preloader-line"></div>
</div>
<div class="page-transition-overlay"></div>

<nav id="nav">
  <a href="/" class="nav-logo">
    <img src="/assets/logo/logo-dark.png" alt="Memorygraph Wedding Studio" style="height:48px;width:auto;max-width:160px;display:block;"/>
  </a>
  <ul class="nav-links">
    <li><a href="/">Home</a></li>
    <li><a href="/stories/" class="active">Stories</a></li>
    <li><a href="/about/">About</a></li>
    <li><a href="/investment/">Investment</a></li>
    <li><a href="/blog/">Journal</a></li>
  </ul>
  <a href="/contact/" class="nav-cta magnetic">Begin Your Story</a>
  <button class="nav-toggle" id="navToggle" aria-label="Open menu" aria-expanded="false">
    <span></span><span></span><span></span>
  </button>
</nav>

<div class="mobile-menu" id="mobileMenu">
  <a href="/">Home</a>
  <a href="/stories/">Stories</a>
  <a href="/about/">About</a>
  <a href="/investment/">Investment</a>
  <a href="/blog/">Journal</a>
  <a href="/contact/" class="mobile-menu-cta">Begin Your Story</a>
</div>

<!-- HERO -->
<div class="page-hero">
  <div class="ph-label reveal">Wedding Stories</div>
  <h1 class="reveal reveal-d1">Love, told in<br><em>frames.</em></h1>
  <p class="ph-sub reveal reveal-d2">Every wedding we photograph becomes a story we carry with us. These are the ones that left a permanent mark.</p>
</div>

<!-- STORIES -->
{% for story in collections.stories %}
<div class="story-row">
  <div class="story-row-img reveal">
    <div class="story-row-corner-tl"></div>
    {% if story.data.hero %}
    <div class="story-row-img-bg" data-bg="{{ story.data.hero }}" style="background-size:cover;background-position:center;"></div>
    {% endif %}
    <div class="story-row-corner-br"></div>
  </div>
  <div class="story-row-body">
    <div class="story-row-label reveal">{{ story.data.location_short }} · {{ story.date | formatDate }}</div>
    <h2 class="story-row-name reveal reveal-d1">{{ story.data.title }}</h2>
    <div class="story-row-loc reveal reveal-d1">{{ story.data.location }}</div>
    {% if story.data.quote %}
    <blockquote class="story-row-quote reveal reveal-d2">{{ story.data.quote }}</blockquote>
    {% endif %}
    {% if story.data.stat_images or story.data.stat_hours or story.data.stat_photographers %}
    <div class="story-row-stats reveal reveal-d2">
      {% if story.data.stat_images %}<div class="story-row-stat"><strong>{{ story.data.stat_images }}</strong><span>Images</span></div>{% endif %}
      {% if story.data.stat_hours %}<div class="story-row-stat"><strong>{{ story.data.stat_hours }}h</strong><span>Coverage</span></div>{% endif %}
      {% if story.data.stat_photographers %}<div class="story-row-stat"><strong>{{ story.data.stat_photographers }}</strong><span>Photographers</span></div>{% endif %}
    </div>
    {% endif %}
    <a href="{{ story.url }}" class="btn-story reveal reveal-d3">View Full Story
      <svg width="16" height="10" viewBox="0 0 16 10" fill="none"><path d="M10 1l5 4-5 4M1 5h14" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/></svg>
    </a>
  </div>
</div>
{% endfor %}

<!-- CTA -->
<div class="cta-strip">
  <div class="cs-label reveal">Your Story Next?</div>
  <h2 class="cs-title reveal reveal-d1">Could yours be the<br>next <em>love story</em>?</h2>
  <p class="cs-sub reveal reveal-d2">Currently booking for 2026 &amp; 2027. Kerala &amp; destination weddings welcome.</p>
  <a href="/contact/" class="btn-gold reveal reveal-d3">Begin Your Story</a>
</div>

<footer>
  <div class="footer-inner">
    <a href="/" class="footer-logo" style="text-decoration:none;">
      <img src="/assets/logo/logo-white.png" alt="Memorygraph Wedding Studio" style="height:52px;width:auto;mix-blend-mode:screen;opacity:.9;"/>
    </a>
    <div class="footer-links-row">
      <a href="/">Home</a>
      <a href="/stories/">Stories</a>
      <a href="/about/">About</a>
      <a href="/investment/">Investment</a>
      <a href="/blog/">Journal</a>
      <a href="/contact/">Contact</a>
    </div>
  </div>
  <div class="footer-bottom">
    <div class="footer-copy">&copy; 2026 Memorygraph Wedding Studio &middot; Thrissur, Kerala</div>
    <div class="footer-socials" style="display:flex;gap:18px;">
      <a href="https://www.instagram.com/memorygraph.weddings/" target="_blank" rel="noopener" style="font-family:var(--sans);font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(244,237,224,.4);text-decoration:none;">Instagram</a>
      <a href="https://www.youtube.com/@MemorygraphWeddings" target="_blank" rel="noopener" style="font-family:var(--sans);font-size:.62rem;letter-spacing:.22em;text-transform:uppercase;color:rgba(244,237,224,.4);text-decoration:none;">YouTube</a>
    </div>
  </div>
</footer>

<!-- MOBILE STICKY CTA -->
<div class="mobile-cta-bar" id="mobileCta">
  <div class="mobile-cta-bar-inner">
    <span class="mobile-cta-bar-text">Season dates filling up</span>
    <a href="/contact/">Begin Your Story</a>
  </div>
</div>

<a href="https://wa.me/919846238073?text=Hi%20Arun%2C%20I%27d%20love%20to%20discuss%20my%20wedding." class="whatsapp-float" data-cms="whatsapp-link" target="_blank">
  <svg viewBox="0 0 32 32" fill="currentColor"><path d="M16 .4C7.4.4.4 7.4.4 16c0 2.84.74 5.62 2.16 8.06L.27 31.6l7.74-2.27C10.36 30.7 13.14 31.5 16 31.5c8.6 0 15.6-7 15.6-15.5C31.6 7.4 24.6.4 16 .4zM16 28.7c-2.5 0-4.96-.66-7.1-1.92l-.5-.3-5.34 1.55 1.6-5.18-.34-.55C2.92 19.92 2.2 18 2.2 16 2.2 8.4 8.4 2.2 16 2.2c7.6 0 13.8 6.2 13.8 13.8 0 7.6-6.2 12.7-13.8 12.7zm7.6-9.8c-.4-.2-2.4-1.18-2.78-1.32-.38-.14-.66-.2-.94.2-.28.4-1.06 1.32-1.3 1.6-.24.28-.48.3-.88.1-.4-.2-1.7-.62-3.24-2-1.2-1.06-2-2.38-2.24-2.78-.24-.4-.02-.62.18-.82.18-.18.4-.46.6-.7.2-.24.26-.4.4-.68.14-.28.06-.52-.04-.72-.1-.2-.92-2.22-1.26-3.04-.34-.8-.68-.7-.94-.72h-.8c-.28 0-.72.1-1.1.5-.38.4-1.44 1.4-1.44 3.42s1.48 3.96 1.68 4.24c.2.28 2.92 4.46 7.08 6.24 1 .42 1.78.68 2.38.88.98.32 1.88.28 2.6.16.78-.12 2.4-.98 2.74-1.92.34-.94.34-1.74.24-1.92-.1-.18-.36-.28-.76-.48z"/></svg>
</a>

<script src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/gsap.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/gsap@3.12/dist/ScrollTrigger.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lenis@1.1/dist/lenis.min.js"></script>
<script src="/assets/js/main.js"></script>

<script>
  const obs=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting){e.target.classList.add('visible');obs.unobserve(e.target);}}),{threshold:.12});
  document.querySelectorAll('.reveal').forEach(r=>obs.observe(r));
</script>
</body>
</html>
