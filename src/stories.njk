<script src="https://cdn.jsdelivr.net/npm/lenis@1.1/dist/lenis.min.js"></script>

<!-- SHARED INTERACTIONS -->
<script src="/assets/js/main.js"></script>

<!-- PAGE-SPECIFIC SCRIPTS -->
<script>
  // Filter buttons
  document.querySelectorAll('.filter-btn').forEach(b=>b.addEventListener('click',()=>{
    document.querySelectorAll('.filter-btn').forEach(x=>x.classList.remove('active'));
    b.classList.add('active');
    const filter = b.textContent.trim().toLowerCase();
    document.querySelectorAll('.story-card-link').forEach(card=>{
      const metaEl = card.querySelector('.s-meta');
      const meta = metaEl ? metaEl.textContent.toLowerCase() : '';
      const hasFilm = !!card.querySelector('.s-tag.video');
      let show = false;
      if (filter === 'all stories') show = true;
      else if (filter === 'with film') show = hasFilm;
      else {
        const key = filter.split(' ')[0];
        show = meta.includes(key);
      }
      card.style.display = show ? '' : 'none';
    });
  }));

  // Legacy reveal fallback
  if (!window.gsap) {
    const obs = new IntersectionObserver(e=>e.forEach(x=>{if(x.isIntersecting){x.target.classList.add('visible');obs.unobserve(x.target);}}),{threshold:.1});
    document.querySelectorAll('.reveal').forEach(r=>obs.observe(r));
  }
</script>

<!-- CMS Loader -->
<script src="/assets/cms-loader.js"></script>
